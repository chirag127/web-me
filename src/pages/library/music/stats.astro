---
/*
 * Data pre-fetched to: public/data/lastfm-user.json, public/data/lb-stats-all.json
 */
import Layout from '~/layouts/Layout.astro'
import { readFileSync } from 'fs'
import { join } from 'path'

function loadJson(name: string, fallback: any = null) {
  try { return JSON.parse(readFileSync(join(process.cwd(), 'public/data', name), 'utf-8')) }
  catch { return fallback }
}

const lfUser: any  = loadJson('lastfm-user.json')
const lbAll: any   = loadJson('lb-stats-all.json')

const since = lfUser?.registered?.unixtime
  ? new Date(Number(lfUser.registered.unixtime) * 1000).getFullYear()
  : null
---

<Layout title="Music Stats" active="/library/music/stats/">
  <div class="page-header">
    <div class="kicker">MUSIC · STATS</div>
    <h1>Listening Stats</h1>
    {since && <p class="muted">Last.fm since {since}</p>}
  </div>

  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-value">{lfUser?.playcount?.toLocaleString?.() ?? '—'}</div>
      <div class="stat-label">TOTAL SCROBBLES</div>
      <div class="stat-source">Last.fm · lastfmwhy</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{lfUser?.artist_count?.toLocaleString?.() ?? '—'}</div>
      <div class="stat-label">ARTISTS</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{lfUser?.track_count?.toLocaleString?.() ?? '—'}</div>
      <div class="stat-label">TRACKS</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{lfUser?.album_count?.toLocaleString?.() ?? '—'}</div>
      <div class="stat-label">ALBUMS</div>
    </div>
  </div>

  <div style="margin-top:1.5rem; display:flex; gap:1rem; flex-wrap:wrap;">
    <a href="https://www.last.fm/user/lastfmwhy" target="_blank" rel="noopener" style="font-size:0.8rem; color:var(--muted)">Last.fm profile ↗</a>
    <a href="https://listenbrainz.org/user/chirag127/" target="_blank" rel="noopener" style="font-size:0.8rem; color:var(--muted)">ListenBrainz profile ↗</a>
  </div>
</Layout>

<style>
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 { font-size: 1.5rem; margin: 0.25rem 0; }
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 0.5rem; }
  .stat-card { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; padding: 0.875rem 1rem; }
  .stat-value { font-family: var(--font-display, Outfit, sans-serif); font-size: 1.5rem; font-weight: 700; color: #818cf8; line-height: 1; margin-bottom: 0.25rem; }
  .stat-label { font-size: 0.65rem; font-family: var(--font-mono, monospace); letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted, #71717a); }
  .stat-source { font-size: 0.65rem; color: var(--faint, #52525b); margin-top: 0.25rem; }
  .muted { color: var(--muted, #71717a); font-size: 0.85rem; }
</style>
