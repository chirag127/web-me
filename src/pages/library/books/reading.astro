---
/*
 * Data pre-fetched to: public/data/moonreader-books.json
 * Source: Moon+ Reader Pro backup (moonreader-backup.zip dropped into public/data/ manually)
 */
import Layout from '~/layouts/Layout.astro'
import { readFileSync, existsSync } from 'fs'
import { join } from 'path'

let books: any[] = []
const dataPath = join(process.cwd(), 'public/data/moonreader-books.json')
try {
  if (existsSync(dataPath)) books = JSON.parse(readFileSync(dataPath, 'utf-8'))
} catch {}

const inProgress = books.filter((b: any) => b.progress_pct > 0 && b.progress_pct < 100)
const completed  = books.filter((b: any) => b.progress_pct === 100)
---

<Layout title="Reading (Moon+)" active="/library/books/">
  <div class="page-header">
    <div class="kicker">BOOKS · READING</div>
    <h1>Currently Reading</h1>
    <p class="muted">Moon+ Reader Pro · {inProgress.length} in progress, {completed.length} completed</p>
  </div>

  {books.length === 0 ? (
    <p class="empty-state">Drop <code>moonreader-backup.zip</code> into <code>public/data/</code> to see your reading progress here.</p>
  ) : (
    <>
      {inProgress.length > 0 && (
        <section>
          <h2 class="section-heading">In Progress</h2>
          <ol class="book-list">
            {inProgress.map((b: any, i: number) => (
              <li class="book-row">
                <span class="rank">{i + 1}</span>
                <div class="book-info">
                  <span class="book-title">{b.title}</span>
                  <div class="progress-wrap">
                    <div class="progress-bar">
                      <div class="progress-fill" style={`width:${b.progress_pct}%`}></div>
                    </div>
                    <span class="progress-label">{b.progress_pct}% · p{b.current_page}/{b.total_pages}</span>
                  </div>
                </div>
              </li>
            ))}
          </ol>
        </section>
      )}

      {completed.length > 0 && (
        <section class="completed-section">
          <h2 class="section-heading">Completed</h2>
          <ol class="book-list">
            {completed.map((b: any, i: number) => (
              <li class="book-row">
                <span class="rank">{i + 1}</span>
                <div class="book-info">
                  <span class="book-title">{b.title}</span>
                  <div class="progress-wrap">
                    <div class="progress-bar">
                      <div class="progress-fill progress-fill--done" style="width:100%"></div>
                    </div>
                    <span class="progress-label">100% · {b.total_pages}p</span>
                  </div>
                </div>
              </li>
            ))}
          </ol>
        </section>
      )}
    </>
  )}
</Layout>

<style>
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 { font-size: 1.5rem; margin: 0.25rem 0; }
  .kicker { font-size: 0.65rem; letter-spacing: 0.1em; color: var(--muted, #71717a); text-transform: uppercase; margin-bottom: 0.25rem; }
  .muted { color: var(--muted, #71717a); font-size: 0.85rem; }
  .section-heading { font-size: 0.85rem; color: var(--muted, #71717a); text-transform: uppercase; letter-spacing: 0.08em; margin: 1.5rem 0 0.5rem; }
  .completed-section { margin-top: 2rem; }
  .book-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 2px; }
  .book-row { display: flex; align-items: flex-start; gap: 0.75rem; padding: 6px 8px; border-radius: 5px; }
  .book-row:hover { background: rgba(255,255,255,0.03); }
  .rank { font-family: var(--font-mono, monospace); font-size: 0.7rem; color: var(--faint, #52525b); width: 2rem; text-align: right; flex-shrink: 0; padding-top: 2px; }
  .book-info { flex: 1; min-width: 0; }
  .book-title { display: block; font-size: 0.8125rem; color: var(--fg, #fff); margin-bottom: 4px; }
  .progress-wrap { display: flex; align-items: center; gap: 0.5rem; }
  .progress-bar { flex: 1; height: 4px; background: rgba(255,255,255,0.08); border-radius: 2px; overflow: hidden; max-width: 180px; }
  .progress-fill { height: 100%; background: #818cf8; border-radius: 2px; transition: width 0.3s; }
  .progress-fill--done { background: #34d399; }
  .progress-label { font-size: 0.7rem; color: var(--muted, #71717a); white-space: nowrap; }
  .empty-state { color: var(--muted, #71717a); font-size: 0.85rem; padding: 1rem 0; }
  .empty-state code { font-family: var(--font-mono, monospace); background: rgba(255,255,255,0.06); padding: 1px 4px; border-radius: 3px; }
</style>
