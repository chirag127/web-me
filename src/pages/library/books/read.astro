---
/*
 * API: https://api.hardcover.app/v1/graphql
 * Data pre-fetched to: public/data/hardcover-read.json
 * Hardcover profile: https://hardcover.app/@chirag127
 */
import Layout from '~/layouts/Layout.astro'
import { readFileSync } from 'fs'
import { join } from 'path'

let read: any[] = []
try { read = JSON.parse(readFileSync(join(process.cwd(), 'public/data/hardcover-read.json'), 'utf-8')) }
catch {}
---

<Layout title="Books Read" active="/library/books/">
  <div class="page-header">
    <div class="kicker">BOOKS · READ</div>
    <h1>Read</h1>
    <p class="muted">{read.length} books · <a href="https://hardcover.app/@chirag127" target="_blank" rel="noopener">Hardcover ↗</a></p>
  </div>

  {read.length === 0 ? (
    <p class="muted">No books marked as read yet · <a href="https://hardcover.app/@chirag127" target="_blank" rel="noopener">Add on Hardcover ↗</a></p>
  ) : (
    <ol class="subject-list">
      {read.map((b: any, i: number) => (
        <li class="subject-row">
          <span class="rank">{i + 1}</span>
          {b.cover && <img src={b.cover} alt={b.title} class="cover" loading="lazy" />}
          <div class="subject-info">
            <a href={`https://hardcover.app/books/${b.slug}`} target="_blank" rel="noopener" class="subject-name">{b.title}</a>
            <span class="subject-sub">{b.author}</span>
          </div>
          {b.rating && <span class="subject-meta">{'★'.repeat(Number(b.rating))}</span>}
        </li>
      ))}
    </ol>
  )}
</Layout>

<style>
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 { font-size: 1.5rem; margin: 0.25rem 0; }
  .subject-list { list-style: none; display: flex; flex-direction: column; gap: 2px; }
  .subject-row { display: flex; align-items: center; gap: 0.75rem; padding: 5px 8px; border-radius: 5px; }
  .subject-row:hover { background: rgba(255,255,255,0.03); }
  .rank { font-family: var(--font-mono, monospace); font-size: 0.7rem; color: var(--faint, #52525b); width: 2rem; text-align: right; flex-shrink: 0; }
  .cover { width: 28px; height: 42px; border-radius: 2px; object-fit: cover; flex-shrink: 0; }
  .subject-info { flex: 1; min-width: 0; }
  .subject-name { display: block; font-size: 0.8125rem; color: var(--fg, #fff); text-decoration: none; }
  .subject-name:hover { color: #818cf8; }
  .subject-sub { display: block; font-size: 0.72rem; color: var(--muted, #71717a); }
  .subject-meta { font-size: 0.72rem; color: #f59e0b; white-space: nowrap; }
  .muted { color: var(--muted, #71717a); font-size: 0.85rem; }
</style>
