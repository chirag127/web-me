---
/*
 * Steam API: https://api.steampowered.com/IPlayerService/GetRecentlyPlayedGames/v0001/?steamid=STEAM_ID&key=STEAM_KEY&format=json
 * Steam profile: https://steamcommunity.com/id/chirag127/
 * Note: Set STEAM_API_KEY + STEAM_USER_ID in CF Pages env vars to enable.
 * Without key: links to Steam profile directly.
 */
import Layout from '~/layouts/Layout.astro'
---

<Layout title="Gaming" active="/library/gaming/">
  <div class="page-header">
    <div class="kicker">LIBRARY · GAMING</div>
    <h1>Gaming</h1>
  </div>

  <div class="empty-state">
    <p>Steam integration coming soon.</p>
    <p style="font-size:0.75rem;margin-top:0.5rem;color:var(--faint)">
      Set <code>STEAM_API_KEY</code> + <code>STEAM_USER_ID</code> in CF Pages env vars.<br/>
      API: <code style="font-size:0.7rem">api.steampowered.com/IPlayerService/GetRecentlyPlayedGames/v0001/</code>
    </p>
    <div style="margin-top:1rem;display:flex;gap:0.75rem;flex-wrap:wrap">
      <a href="https://steamcommunity.com/id/chirag127/" target="_blank" rel="noopener" style="font-size:0.8rem;color:var(--muted)">Steam profile ↗</a>
    </div>
  </div>
</Layout>

<style>
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 { font-size: 1.5rem; margin: 0.25rem 0; }
  .empty-state { padding: 2rem; background: rgba(255,255,255,0.02); border: 1px dashed rgba(255,255,255,0.06); border-radius: 8px; font-size: 0.875rem; color: var(--muted, #71717a); }
</style>
