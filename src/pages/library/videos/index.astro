---
import { readFileSync } from 'node:fs'
import { resolve } from 'node:path'
import Layout from '~/layouts/Layout.astro'

let recentVideos: any[] = []
let statsData: any = null
let dataError = ''

try {
  const statsPath = resolve('public/data/youtube-stats.json')
  statsData = JSON.parse(readFileSync(statsPath, 'utf-8'))
} catch {
  // no stats yet
}

try {
  const recentPath = resolve('public/data/youtube-recent.json')
  recentVideos = JSON.parse(readFileSync(recentPath, 'utf-8'))
} catch {
  // no recent yet
}

const hasData = statsData && (statsData.totalWatched > 0 || statsData.topChannels?.length > 0)
---

<Layout title="Videos" active="/library/videos/">
  <div class="page-header">
    <div class="kicker">LIBRARY · VIDEOS</div>
    <h1>Videos</h1>
    <p class="subtitle">YouTube watch history via Google Takeout</p>
  </div>

  {hasData ? (
    <div class="data-view">
      <div class="stats-row">
        <div class="stat-card card">
          <div class="stat-number">{statsData.totalWatched?.toLocaleString() ?? '—'}</div>
          <div class="stat-label">Videos watched</div>
        </div>
        {statsData.totalChannels && (
          <div class="stat-card card">
            <div class="stat-number">{statsData.totalChannels.toLocaleString()}</div>
            <div class="stat-label">Unique channels</div>
          </div>
        )}
        {statsData.updatedAt && (
          <div class="stat-card card">
            <div class="stat-number updated-at">{new Date(statsData.updatedAt).toLocaleDateString('en-IN', { month: 'short', year: 'numeric' })}</div>
            <div class="stat-label">Last updated</div>
          </div>
        )}
      </div>

      {statsData.topChannels?.length > 0 && (
        <section class="section">
          <h2 class="section-title">Top Channels</h2>
          <div class="channel-list card">
            {statsData.topChannels.slice(0, 10).map((ch: any, i: number) => (
              <div class="channel-row">
                <span class="rank">#{i + 1}</span>
                <span class="channel-name">{ch.name ?? ch.channel}</span>
                <span class="badge">{(ch.count ?? ch.videos ?? 0).toLocaleString()}</span>
              </div>
            ))}
          </div>
        </section>
      )}

      {recentVideos.length > 0 && (
        <section class="section">
          <h2 class="section-title">Recently Watched</h2>
          <div class="video-grid">
            {recentVideos.slice(0, 12).map((v: any) => (
              <a
                class="video-card card"
                href={v.url ?? `https://www.youtube.com/watch?v=${v.videoId}`}
                target="_blank"
                rel="noopener"
              >
                {v.thumbnail && (
                  <div class="thumb-wrap">
                    <img src={v.thumbnail} alt="" loading="lazy" class="thumb" />
                  </div>
                )}
                <div class="video-info">
                  <div class="video-title">{v.title}</div>
                  {v.channel && <div class="video-channel">{v.channel}</div>}
                  {v.watchedAt && (
                    <div class="video-date">{new Date(v.watchedAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}</div>
                  )}
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  ) : (
    <div class="empty-view">
      <div class="card setup-card">
        <div class="setup-header">
          <span class="kicker">SETUP GUIDE</span>
          <h2>Connect your watch history</h2>
          <p class="muted-sm">YouTube Data API v3 doesn't expose watch history for privacy reasons. Use Google Takeout instead.</p>
        </div>

        <ol class="steps">
          <li>
            <span class="step-num">1</span>
            <div>
              <strong>Go to <a href="https://takeout.google.com" target="_blank" rel="noopener">takeout.google.com</a></strong>
              <p>Sign in with your Google account.</p>
            </div>
          </li>
          <li>
            <span class="step-num">2</span>
            <div>
              <strong>Select "YouTube and YouTube Music"</strong>
              <p>Deselect everything else. Under YouTube, choose <code>history</code> → <code>watch-history</code>.</p>
            </div>
          </li>
          <li>
            <span class="step-num">3</span>
            <div>
              <strong>Choose export settings</strong>
              <p>Format: <code>JSON</code>. Delivery: "Export to Google Drive". Frequency: "Every month".</p>
            </div>
          </li>
          <li>
            <span class="step-num">4</span>
            <div>
              <strong>Auto-parsed by GHA</strong>
              <p>The workflow at <code>.github/workflows/process-takeout.yml</code> picks up the export and writes <code>public/data/youtube-stats.json</code> and <code>public/data/youtube-recent.json</code>.</p>
            </div>
          </li>
          <li>
            <span class="step-num">5</span>
            <div>
              <strong>Videos appear after next daily refresh</strong>
              <p>This page re-reads the JSON files at build time. Trigger a deploy or wait for the daily cron.</p>
            </div>
          </li>
        </ol>
      </div>

      <div class="card why-card">
        <span class="kicker">WHY NO LIVE API?</span>
        <p>YouTube Data API v3 exposes public channel data (playlists, uploads, stats) but deliberately omits watch history — it's private per Google's privacy policy. The only first-party export path is Google Takeout. Takeout produces a <code>watch-history.json</code> with full timestamps and video metadata, which this pipeline parses and stores locally.</p>
      </div>

      <div class="channel-link-row">
        <a href="https://www.youtube.com/channel/UC1hhJNIRqhARaF7nknBb2xA" target="_blank" rel="noopener" class="channel-link">
          YouTube channel ↗
        </a>
      </div>
    </div>
  )}
</Layout>

<style>
  .page-header { margin-bottom: 2rem; }
  .page-header h1 { font-size: 2rem; font-weight: 700; margin: 0.25rem 0 0.5rem; }
  .subtitle { color: var(--muted, #71717a); font-size: 0.9rem; margin: 0; }

  .kicker {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted, #71717a);
    margin-bottom: 0.4rem;
  }

  .card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    padding: 1.25rem;
  }

  .badge {
    background: rgba(255,255,255,0.06);
    border-radius: 20px;
    padding: 0.15rem 0.5rem;
    font-size: 0.72rem;
    color: var(--muted, #a1a1aa);
    font-variant-numeric: tabular-nums;
  }

  /* Stats row */
  .stats-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .stat-card {
    flex: 1;
    min-width: 120px;
    text-align: center;
  }
  .stat-number {
    font-size: 2rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1.1;
  }
  .updated-at { font-size: 1.2rem; }
  .stat-label {
    font-size: 0.72rem;
    color: var(--muted, #71717a);
    margin-top: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Sections */
  .section { margin-bottom: 2rem; }
  .section-title {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted, #71717a);
    margin-bottom: 0.75rem;
  }

  /* Channel list */
  .channel-list { padding: 0; overflow: hidden; }
  .channel-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .channel-row:last-child { border-bottom: none; }
  .rank {
    font-size: 0.7rem;
    color: var(--faint, #52525b);
    width: 1.5rem;
    flex-shrink: 0;
  }
  .channel-name {
    flex: 1;
    font-size: 0.875rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Video grid */
  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
  }
  .video-card {
    display: flex;
    flex-direction: column;
    padding: 0;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }
  .video-card:hover { border-color: rgba(255,255,255,0.15); }
  .thumb-wrap { aspect-ratio: 16/9; overflow: hidden; background: rgba(255,255,255,0.04); }
  .thumb { width: 100%; height: 100%; object-fit: cover; display: block; }
  .video-info { padding: 0.75rem; }
  .video-title {
    font-size: 0.8rem;
    font-weight: 500;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .video-channel {
    font-size: 0.7rem;
    color: var(--muted, #71717a);
    margin-top: 0.3rem;
  }
  .video-date {
    font-size: 0.65rem;
    color: var(--faint, #52525b);
    margin-top: 0.2rem;
  }

  /* Empty / setup */
  .empty-view { display: flex; flex-direction: column; gap: 1.25rem; }

  .setup-card { }
  .setup-header { margin-bottom: 1.25rem; }
  .setup-header h2 { font-size: 1.1rem; font-weight: 600; margin: 0.25rem 0 0.5rem; }
  .muted-sm { font-size: 0.825rem; color: var(--muted, #71717a); margin: 0; }

  .steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .steps li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .step-num {
    flex-shrink: 0;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--muted, #a1a1aa);
  }
  .steps li strong { font-size: 0.875rem; display: block; margin-bottom: 0.2rem; }
  .steps li p { font-size: 0.8rem; color: var(--muted, #71717a); margin: 0; }
  .steps li a { color: inherit; }
  .steps code {
    font-size: 0.72rem;
    background: rgba(255,255,255,0.06);
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }

  .why-card p {
    font-size: 0.825rem;
    color: var(--muted, #71717a);
    line-height: 1.6;
    margin: 0.5rem 0 0;
  }
  .why-card code {
    font-size: 0.75rem;
    background: rgba(255,255,255,0.06);
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }

  .channel-link-row { text-align: center; }
  .channel-link {
    font-size: 0.8rem;
    color: var(--muted, #71717a);
    text-decoration: none;
  }
  .channel-link:hover { color: inherit; }
</style>
