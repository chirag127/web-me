---
import { readFileSync } from 'node:fs'
import { resolve } from 'node:path'
import Layout from '~/layouts/Layout.astro'

let recentVideos: Array<{ title: string; url: string; channel: string; time: string }> = []
let statsData: { total: number; top_channels: Array<{ name: string; count: number }>; last_updated: string } | null = null

try {
  statsData = JSON.parse(readFileSync(resolve('public/data/youtube-stats.json'), 'utf-8'))
} catch { /* no stats yet */ }

try {
  recentVideos = JSON.parse(readFileSync(resolve('public/data/youtube-recent.json'), 'utf-8'))
} catch { /* no recent yet */ }

const hasData = statsData && statsData.total > 0

const top15 = statsData?.top_channels?.slice(0, 15) ?? []
const maxCount = top15[0]?.count ?? 1
const topChannelName = top15[0]?.name ?? '—'
const uniqueChannels = statsData?.top_channels?.length ?? 0
const recent20 = recentVideos.slice(0, 20)

function decode(s: string) {
  return s
    .replace(/&amp;/g, '&')
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
}
---

<Layout title="Videos" active="/library/videos/">
  <div class="page-header">
    <div class="kicker">LIBRARY · VIDEOS</div>
    <h1>Videos</h1>
    <p class="subtitle">YouTube watch history via Google Takeout.</p>
  </div>

  {hasData ? (
    <div class="data-view">
      <!-- Stat cards -->
      <div class="stats-row">
        <div class="stat-card card">
          <div class="stat-number">{statsData!.total.toLocaleString()}</div>
          <div class="stat-label">Videos watched</div>
        </div>
        <div class="stat-card card">
          <div class="stat-number top-ch">{topChannelName}</div>
          <div class="stat-label">Top channel</div>
        </div>
        <div class="stat-card card">
          <div class="stat-number">{uniqueChannels.toLocaleString()}+</div>
          <div class="stat-label">Unique channels</div>
        </div>
        <div class="stat-card card">
          <div class="stat-number date-num">{statsData!.last_updated}</div>
          <div class="stat-label">Last updated</div>
        </div>
      </div>

      <!-- Top channels bar chart -->
      {top15.length > 0 && (
        <section class="section">
          <h2 class="section-title">Top Channels</h2>
          <div class="bar-chart card">
            {top15.map((ch, i) => (
              <div class="bar-row">
                <span class="bar-rank">#{i + 1}</span>
                <span class="bar-name">{ch.name}</span>
                <div class="bar-track">
                  <div class="bar-fill" style={`width:${Math.round((ch.count / maxCount) * 100)}%`} />
                </div>
                <span class="bar-count">{ch.count.toLocaleString()}</span>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Recent watches -->
      {recent20.length > 0 && (
        <section class="section">
          <h2 class="section-title">Recently Watched</h2>
          <div class="video-list card">
            {recent20.map((v) => (
              <a class="video-row" href={v.url} target="_blank" rel="noopener noreferrer">
                <div class="video-meta">
                  <span class="video-title">{decode(v.title)}</span>
                  <span class="video-channel">{v.channel}</span>
                </div>
                <span class="video-time">{v.time}</span>
              </a>
            ))}
          </div>
        </section>
      )}

      <p class="last-updated">Updated {statsData!.last_updated}</p>
    </div>
  ) : (
    <div class="empty-view">
      <div class="card setup-card">
        <span class="kicker">SETUP GUIDE</span>
        <h2>Connect your watch history</h2>
        <p class="muted-sm">YouTube Data API v3 doesn't expose watch history. Use Google Takeout instead.</p>
        <ol class="steps">
          <li>
            <span class="step-num">1</span>
            <div>
              <strong>Go to <a href="https://takeout.google.com" target="_blank" rel="noopener">takeout.google.com</a></strong>
              <p>Sign in with your Google account.</p>
            </div>
          </li>
          <li>
            <span class="step-num">2</span>
            <div>
              <strong>Select "YouTube and YouTube Music"</strong>
              <p>Deselect everything else. Under YouTube, choose <code>history</code> → <code>watch-history</code>.</p>
            </div>
          </li>
          <li>
            <span class="step-num">3</span>
            <div>
              <strong>Export as JSON</strong>
              <p>Format: <code>JSON</code>. Delivery: Google Drive. Frequency: monthly.</p>
            </div>
          </li>
          <li>
            <span class="step-num">4</span>
            <div>
              <strong>Run the parser</strong>
              <p>The workflow at <code>.github/workflows/process-takeout.yml</code> writes <code>public/data/youtube-stats.json</code> and <code>youtube-recent.json</code>.</p>
            </div>
          </li>
          <li>
            <span class="step-num">5</span>
            <div>
              <strong>Deploy</strong>
              <p>This page re-reads the JSON at build time. Trigger a deploy or wait for the daily cron.</p>
            </div>
          </li>
        </ol>
      </div>
    </div>
  )}
</Layout>

<style>
  /* Base */
  .page-header { margin-bottom: 2rem; }
  .page-header h1 { font-size: 2rem; font-weight: 700; margin: 0.25rem 0 0.5rem; }
  .subtitle { color: var(--muted, #71717a); font-size: 0.9rem; margin: 0; }

  .kicker {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted, #71717a);
    margin-bottom: 0.4rem;
    display: block;
  }

  .card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    padding: 1.25rem;
  }

  /* Stat cards */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  @media (max-width: 640px) {
    .stats-row { grid-template-columns: repeat(2, 1fr); }
  }
  .stat-card { text-align: center; }
  .stat-number {
    font-size: 1.75rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1.1;
    word-break: break-word;
  }
  .top-ch { font-size: 0.85rem; font-weight: 600; line-height: 1.3; margin: 0.2rem 0; }
  .date-num { font-size: 0.9rem; font-weight: 600; }
  .stat-label {
    font-size: 0.68rem;
    color: var(--muted, #71717a);
    margin-top: 0.3rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Sections */
  .section { margin-bottom: 2rem; }
  .section-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted, #71717a);
    margin-bottom: 0.75rem;
  }

  /* Bar chart */
  .bar-chart { padding: 0.75rem 1.25rem; }
  .bar-row {
    display: grid;
    grid-template-columns: 2rem 1fr auto auto;
    align-items: center;
    gap: 0.6rem;
    padding: 0.35rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .bar-row:last-child { border-bottom: none; }
  .bar-rank {
    font-size: 0.65rem;
    color: var(--faint, #52525b);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .bar-name {
    font-size: 0.8rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .bar-track {
    width: 120px;
    height: 6px;
    background: rgba(255,255,255,0.06);
    border-radius: 3px;
    overflow: hidden;
    flex-shrink: 0;
  }
  @media (max-width: 480px) {
    .bar-track { display: none; }
    .bar-row { grid-template-columns: 2rem 1fr auto; }
  }
  .bar-fill {
    height: 100%;
    background: linear-gradient(90deg, #6366f1, #818cf8);
    border-radius: 3px;
    min-width: 2px;
  }
  .bar-count {
    font-size: 0.7rem;
    color: var(--muted, #71717a);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  /* Video list */
  .video-list { padding: 0; overflow: hidden; }
  .video-row {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.7rem 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    text-decoration: none;
    color: inherit;
    transition: background 0.12s;
  }
  .video-row:last-child { border-bottom: none; }
  .video-row:hover { background: rgba(255,255,255,0.03); }
  .video-meta {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .video-title {
    font-size: 0.82rem;
    font-weight: 500;
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .video-channel {
    font-size: 0.7rem;
    color: var(--muted, #71717a);
  }
  .video-time {
    font-size: 0.65rem;
    color: var(--faint, #52525b);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.1rem;
  }

  .last-updated {
    font-size: 0.7rem;
    color: var(--faint, #52525b);
    text-align: center;
    margin-top: -0.5rem;
  }

  /* Empty / setup */
  .empty-view { display: flex; flex-direction: column; gap: 1.25rem; }
  .setup-card h2 { font-size: 1.1rem; font-weight: 600; margin: 0.3rem 0 0.5rem; }
  .muted-sm { font-size: 0.825rem; color: var(--muted, #71717a); margin: 0 0 1.25rem; }
  .steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .steps li { display: flex; gap: 0.9rem; align-items: flex-start; }
  .step-num {
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--muted, #a1a1aa);
  }
  .steps li strong { font-size: 0.85rem; display: block; margin-bottom: 0.15rem; }
  .steps li p { font-size: 0.78rem; color: var(--muted, #71717a); margin: 0; }
  .steps li a { color: inherit; }
  .steps code {
    font-size: 0.7rem;
    background: rgba(255,255,255,0.06);
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }
</style>
