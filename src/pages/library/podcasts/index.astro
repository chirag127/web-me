---
/*
 * No standard podcast tracking API with public data.
 * Potential: Podchaser, Goodpods, PocketCasts public profile, or manual list.
 * This page is a placeholder with manual curated list.
 */
import Layout from '~/layouts/Layout.astro'

const PODCASTS = [
  { title: 'Lex Fridman Podcast', host: 'Lex Fridman', url: 'https://lexfridman.com/podcast/' },
  { title: 'Huberman Lab', host: 'Andrew Huberman', url: 'https://hubermanlab.com/podcast/' },
  { title: 'The Tim Ferriss Show', host: 'Tim Ferriss', url: 'https://tim.blog/podcast/' },
  { title: 'Darknet Diaries', host: 'Jack Rhysider', url: 'https://darknetdiaries.com/' },
  { title: 'Software Engineering Daily', host: 'Jeff Meyerson', url: 'https://softwareengineeringdaily.com/' },
  { title: 'Changelog', host: 'Adam Stacoviak', url: 'https://changelog.com/podcast' },
]
---

<Layout title="Podcasts" active="/library/podcasts/">
  <div class="page-header">
    <div class="kicker">LIBRARY · PODCASTS</div>
    <h1>Podcasts</h1>
    <p class="muted">Curated list · no API (manual)</p>
  </div>

  <ol class="subject-list">
    {PODCASTS.map((p, i) => (
      <li class="subject-row">
        <span class="rank">{i + 1}</span>
        <div class="subject-info">
          <a href={p.url} target="_blank" rel="noopener" class="subject-name">{p.title}</a>
          <span class="subject-sub">{p.host}</span>
        </div>
      </li>
    ))}
  </ol>
</Layout>

<style>
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 { font-size: 1.5rem; margin: 0.25rem 0; }
  .subject-list { list-style: none; display: flex; flex-direction: column; gap: 2px; }
  .subject-row { display: flex; align-items: center; gap: 0.75rem; padding: 5px 8px; border-radius: 5px; }
  .subject-row:hover { background: rgba(255,255,255,0.03); }
  .rank { font-family: var(--font-mono, monospace); font-size: 0.7rem; color: var(--faint, #52525b); width: 1.75rem; text-align: right; flex-shrink: 0; }
  .subject-info { flex: 1; min-width: 0; }
  .subject-name { display: block; font-size: 0.8125rem; color: var(--fg, #fff); text-decoration: none; }
  .subject-name:hover { color: #818cf8; }
  .subject-sub { display: block; font-size: 0.72rem; color: var(--muted, #71717a); }
</style>
