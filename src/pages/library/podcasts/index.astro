---
import { readFileSync, existsSync } from 'fs'
import { join } from 'path'
import Layout from '~/layouts/Layout.astro'

const dataFile = join(process.cwd(), 'public', 'data', 'podcasts-enriched.json')
const PODCASTS: any[] = existsSync(dataFile)
  ? JSON.parse(readFileSync(dataFile, 'utf-8'))
  : [
      { title: 'Lex Fridman Podcast', feedUrl: 'https://lexfridman.com/feed/podcast/' },
      { title: 'Huberman Lab', feedUrl: 'https://feeds.megaphone.fm/hubermanlab' },
      { title: 'The Tim Ferriss Show', feedUrl: 'https://rss.art19.com/tim-ferriss-show' },
      { title: 'Darknet Diaries', feedUrl: 'https://feeds.megaphone.fm/darknetdiaries' },
      { title: 'Software Engineering Daily', feedUrl: 'https://softwareengineeringdaily.com/feed/podcast/' },
      { title: 'Changelog', feedUrl: 'https://changelog.com/podcast/feed' },
    ]

const enriched = PODCASTS.some(p => p.image || p.description)
---

<Layout title="Podcasts" active="/library/podcasts/">
  <div class="page-header">
    <div class="kicker">LIBRARY · PODCASTS</div>
    <h1>Podcasts</h1>
    <p class="muted">{enriched ? 'Podcast Index enriched' : 'Manual list · Podcast Index key pending'}</p>
  </div>

  <ol class="podcast-list">
    {PODCASTS.map((p, i) => (
      <li class="podcast-row">
        {p.image
          ? <img src={p.image} alt={p.title} class="pod-thumb" loading="lazy" />
          : <div class="pod-thumb pod-thumb--placeholder" />
        }
        <div class="pod-info">
          <a href={p.feedUrl ?? '#'} target="_blank" rel="noopener" class="pod-title">{p.title}</a>
          {p.description && <p class="pod-desc">{p.description.slice(0, 120)}{p.description.length > 120 ? '…' : ''}</p>}
          {p.episodeCount && <span class="pod-meta">{p.episodeCount} episodes</span>}
        </div>
        <span class="rank">{i + 1}</span>
      </li>
    ))}
  </ol>
</Layout>

<style>
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 { font-size: 1.5rem; margin: 0.25rem 0; }
  .podcast-list { list-style: none; display: flex; flex-direction: column; gap: 4px; }
  .podcast-row { display: flex; align-items: flex-start; gap: 0.75rem; padding: 6px 8px; border-radius: 6px; }
  .podcast-row:hover { background: rgba(255,255,255,0.03); }
  .pod-thumb { width: 48px; height: 48px; border-radius: 6px; object-fit: cover; flex-shrink: 0; }
  .pod-thumb--placeholder { background: rgba(255,255,255,0.06); }
  .pod-info { flex: 1; min-width: 0; }
  .pod-title { display: block; font-size: 0.8125rem; color: var(--fg, #fff); text-decoration: none; font-weight: 500; }
  .pod-title:hover { color: #818cf8; }
  .pod-desc { font-size: 0.7rem; color: var(--muted, #71717a); margin: 2px 0 0; line-height: 1.4; }
  .pod-meta { font-size: 0.68rem; color: var(--faint, #52525b); }
  .rank { font-family: var(--font-mono, monospace); font-size: 0.7rem; color: var(--faint, #52525b); width: 1.75rem; text-align: right; flex-shrink: 0; align-self: center; }
</style>
