---
import Layout from '~/layouts/Layout.astro'
import { readFileSync } from 'fs'
import { join } from 'path'

function loadJson(name: string, fallback: any = []) {
  try { return JSON.parse(readFileSync(join(process.cwd(), 'public/data', name), 'utf-8')) }
  catch { return fallback }
}

const showsRaw: any[] = loadJson('trakt-shows-enriched.json')
const stats: any      = loadJson('trakt-stats.json', {})

// Deduplicate by show title; keeps all shows
const unique = new Map<string, any>()
for (const item of showsRaw) {
  if (item.show && !unique.has(item.show.title)) unique.set(item.show.title, item)
}
const shows = [...unique.values()]
const totalShows = stats?.shows?.watched ?? shows.length
const totalEp    = stats?.episodes?.watched ?? '—'
const totalHours = Math.round((stats?.episodes?.minutes ?? 0) / 60)
---

<Layout title="Completed Shows" active="/library/tv/">
  <div class="page-header">
    <div class="kicker">TV · COMPLETED</div>
    <h1>Completed Shows</h1>
    <p class="muted">{totalShows} shows · {totalEp} episodes · {totalHours}h · via <a href="https://trakt.tv/users/chirag127" target="_blank" rel="noopener">Trakt.tv ↗</a></p>
  </div>

  {shows.length === 0 ? (
    <div class="empty-state">
      <p>No shows tracked yet · check back soon</p>
    </div>
  ) : (
    <div class="poster-grid">
      {shows.map((item: any) => (
        <a href={`https://www.themoviedb.org/tv/${item.show?.ids?.tmdb}`} target="_blank" rel="noopener" class="poster-card">
          {item._tmdb?.poster ? (
            <div class="poster-wrap">
              <img src={item._tmdb.poster} alt={item.show?.title ?? ''}
                class="poster-img" loading="lazy" onerror="this.style.display='none'" />
              {item._tmdb?.rating && <span class="rating-badge">{item._tmdb.rating.toFixed(1)}</span>}
            </div>
          ) : (
            <div class="poster-placeholder"></div>
          )}
          <div class="poster-title">{item.show?.title}</div>
          <div class="poster-year">{item.show?.year}</div>
        </a>
      ))}
    </div>
  )}

  <nav class="sub-nav" style="margin-top:1.5rem">
    <a href="/library/tv/">← All Shows</a>
    <a href="/library/tv/watching/">Currently Watching →</a>
  </nav>
</Layout>

<style>
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 { font-size: 1.5rem; margin: 0.25rem 0; }
  .muted { color: var(--muted, #71717a); font-size: 0.85rem; }
  .poster-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 0.75rem; }
  .poster-card { display: flex; flex-direction: column; gap: 4px; text-decoration: none; }
  .poster-card:hover .poster-title { color: #fff; }
  .poster-wrap { position: relative; }
  .poster-img { width: 100%; aspect-ratio: 2/3; object-fit: cover; border-radius: 5px; background: rgba(255,255,255,0.04); display: block; }
  .poster-placeholder { width: 100%; aspect-ratio: 2/3; background: rgba(255,255,255,0.04); border-radius: 5px; }
  .rating-badge { position: absolute; bottom: 4px; right: 4px; background: rgba(0,0,0,0.7); color: #fbbf24; font-size: 0.65rem; font-family: var(--font-mono, monospace); padding: 1px 4px; border-radius: 3px; }
  .poster-title { font-size: 0.72rem; color: var(--fg, #fff); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .poster-year { font-size: 0.65rem; color: var(--muted, #71717a); }
  .empty-state { padding: 2rem; background: rgba(255,255,255,0.02); border: 1px dashed rgba(255,255,255,0.06); border-radius: 8px; font-size: 0.875rem; color: var(--muted, #71717a); }
  .sub-nav { display: flex; flex-direction: column; gap: 6px; }
  .sub-nav a { font-size: 0.875rem; color: var(--muted, #71717a); text-decoration: none; padding: 6px 10px; border-radius: 6px; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); transition: background 120ms; }
  .sub-nav a:hover { background: rgba(255,255,255,0.04); color: #fff; }
</style>
