---
/*
 * API (movie hub): combine watched + watchlist stats from Trakt
 * https://api.trakt.tv/users/chirag127/stats
 */
import Layout from '~/layouts/Layout.astro'
import { getTraktStats } from '~/lib/api'

const stats = await getTraktStats()
const s = stats as any
---

<Layout title="Movies" active="/library/movies/">
  <div class="page-header">
    <div class="kicker">LIBRARY · MOVIES</div>
    <h1>Movies</h1>
    <p class="muted">Tracked via <a href="https://trakt.tv/users/chirag127" target="_blank" rel="noopener">Trakt.tv ↗</a></p>
  </div>

  <div class="stats-row">
    <div class="stat"><span class="val">{s?.movies?.watched ?? '—'}</span><span class="lbl">WATCHED</span></div>
    <div class="divider"></div>
    <div class="stat"><span class="val">{Math.round((s?.movies?.minutes ?? 0)/60)}</span><span class="lbl">HOURS</span></div>
    <div class="divider"></div>
    <div class="stat"><span class="val">{s?.movies?.collected ?? '—'}</span><span class="lbl">COLLECTED</span></div>
  </div>

  <nav class="sub-nav">
    <a href="/library/movies/watched/">Watched →</a>
    <a href="/library/movies/watchlist/">Watchlist →</a>
    <a href="/library/activity/">Activity feed →</a>
  </nav>
</Layout>

<style>
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 { font-size: 1.5rem; margin: 0.25rem 0; }
  .stats-row { display: flex; align-items: center; gap: 1.5rem; margin-bottom: 1.5rem; }
  .stat { display: flex; flex-direction: column; gap: 2px; }
  .val { font-family: var(--font-display, Outfit); font-size: 1.5rem; font-weight: 700; color: #818cf8; line-height: 1; }
  .lbl { font-size: 0.65rem; font-family: var(--font-mono, monospace); letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted, #71717a); }
  .divider { width: 1px; height: 2rem; background: rgba(255,255,255,0.08); }
  .sub-nav { display: flex; flex-direction: column; gap: 6px; }
  .sub-nav a { font-size: 0.875rem; color: var(--muted, #71717a); text-decoration: none; padding: 6px 10px; border-radius: 6px; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); transition: background 120ms; }
  .sub-nav a:hover { background: rgba(255,255,255,0.04); color: #fff; }
</style>
