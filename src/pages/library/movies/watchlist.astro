---
/*
 * Data pre-fetched to: public/data/trakt-watchlist-enriched.json
 */
import Layout from '~/layouts/Layout.astro'
import { readFileSync } from 'fs'
import { join } from 'path'

let watchlist: any[] = []
try { watchlist = JSON.parse(readFileSync(join(process.cwd(), 'public/data/trakt-watchlist-enriched.json'), 'utf-8')) } catch {}
---

<Layout title="Movie Watchlist" active="/library/movies/watchlist/">
  <div class="page-header">
    <div class="kicker">MOVIES · WATCHLIST</div>
    <h1>Watchlist</h1>
    <p class="muted">{watchlist.length} movies queued</p>
  </div>

  {watchlist.length === 0 ? (
    <div class="empty-state">
      <p>No data yet · check back soon</p>
      <p style="font-size:0.75rem;margin-top:0.5rem">
        <a href="https://trakt.tv/users/chirag127/watchlist" target="_blank" rel="noopener">trakt.tv/users/chirag127/watchlist ↗</a>
      </p>
    </div>
  ) : (
    <div class="poster-grid">
      {watchlist.filter((w: any) => w.movie).map((w: any) => (
        <a href={`https://www.themoviedb.org/movie/${w.movie?.ids?.tmdb}`} target="_blank" rel="noopener" class="poster-card">
          {w._tmdb?.poster ? (
            <div class="poster-wrap">
              <img src={`https://image.tmdb.org/t/p/w185${w._tmdb.poster}`} alt={w.movie?.title ?? ''}
                class="poster-img" loading="lazy" onerror="this.style.display='none'" />
              <span class="watchlist-badge">IN WATCHLIST</span>
            </div>
          ) : (
            <div class="poster-placeholder"></div>
          )}
          <div class="poster-title">{w.movie?.title}</div>
          <div class="poster-year">{w.movie?.year}</div>
        </a>
      ))}
    </div>
  )}
</Layout>

<style>
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 { font-size: 1.5rem; margin: 0.25rem 0; }
  .poster-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); gap: 0.75rem; }
  .poster-card { display: flex; flex-direction: column; gap: 4px; text-decoration: none; }
  .poster-card:hover .poster-title { color: #fff; }
  .poster-wrap { position: relative; }
  .poster-img { width: 100%; aspect-ratio: 2/3; object-fit: cover; border-radius: 5px; background: rgba(255,255,255,0.04); display: block; }
  .poster-placeholder { width: 100%; aspect-ratio: 2/3; background: rgba(255,255,255,0.04); border-radius: 5px; }
  .watchlist-badge { position: absolute; bottom: 4px; left: 4px; right: 4px; background: rgba(99,102,241,0.85); color: #fff; font-size: 0.55rem; font-family: var(--font-mono, monospace); letter-spacing: 0.06em; padding: 2px 4px; border-radius: 3px; text-align: center; }
  .poster-title { font-size: 0.72rem; color: var(--fg, #fff); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .poster-year { font-size: 0.65rem; color: var(--muted, #71717a); }
  .empty-state { padding: 2rem; background: rgba(255,255,255,0.02); border: 1px dashed rgba(255,255,255,0.06); border-radius: 8px; font-size: 0.875rem; color: var(--muted, #71717a); }
  .muted { color: var(--muted, #71717a); font-size: 0.85rem; }
</style>
