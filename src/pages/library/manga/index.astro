---
/*
 * MAL API (reading manga): https://api.myanimelist.net/v2/users/chirag127/mangalist?fields=list_status,main_picture,mean&status=reading&limit=100
 * Header: X-MAL-CLIENT-ID: CLIENT_ID
 */
import Layout from '~/layouts/Layout.astro'
import { getMALManga } from '~/lib/api'

const [reading, completed, planToRead] = await Promise.all([
  getMALManga('reading', 50),
  getMALManga('completed', 100),
  getMALManga('plan_to_read', 50),
])
---

<Layout title="Manga" active="/library/manga/">
  <div class="page-header">
    <div class="kicker">LIBRARY · MANGA</div>
    <h1>Manga</h1>
    <p class="muted">via <a href="https://myanimelist.net/profile/chirag127" target="_blank" rel="noopener">MyAnimeList ↗</a></p>
  </div>

  <div class="stats-row">
    <div class="stat"><span class="val">{reading.length}</span><span class="lbl">READING</span></div>
    <div class="divider"></div>
    <div class="stat"><span class="val">{completed.length}</span><span class="lbl">COMPLETED</span></div>
    <div class="divider"></div>
    <div class="stat"><span class="val">{planToRead.length}</span><span class="lbl">QUEUED</span></div>
  </div>

  {reading.length > 0 && (
    <>
      <div class="kicker" style="margin-bottom:0.5rem">CURRENTLY READING</div>
      <ol class="subject-list" style="margin-bottom:1.5rem">
        {reading.map((m: any, i: number) => (
          <li class="subject-row">
            <span class="rank">{i + 1}</span>
            <span class="subject-name">{m.node.title}</span>
            {m.list_status.score > 0 && <span class="subject-meta">★ {m.list_status.score}</span>}
          </li>
        ))}
      </ol>
    </>
  )}

  <nav class="sub-nav">
    <a href="/library/manga/completed/">Completed ({completed.length}) →</a>
    <a href="/library/manga/plan-to-read/">Plan to Read ({planToRead.length}) →</a>
  </nav>
</Layout>

<style>
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 { font-size: 1.5rem; margin: 0.25rem 0; }
  .stats-row { display: flex; align-items: center; gap: 1.5rem; margin-bottom: 1.5rem; }
  .stat { display: flex; flex-direction: column; gap: 2px; }
  .val { font-family: var(--font-display, Outfit); font-size: 1.5rem; font-weight: 700; color: #818cf8; line-height: 1; }
  .lbl { font-size: 0.65rem; font-family: var(--font-mono, monospace); letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted, #71717a); }
  .divider { width: 1px; height: 2rem; background: rgba(255,255,255,0.08); }
  .subject-list { list-style: none; display: flex; flex-direction: column; gap: 2px; }
  .subject-row { display: flex; align-items: center; gap: 0.75rem; padding: 5px 8px; border-radius: 5px; }
  .subject-row:hover { background: rgba(255,255,255,0.03); }
  .rank { font-family: var(--font-mono, monospace); font-size: 0.7rem; color: var(--faint, #52525b); width: 1.75rem; text-align: right; flex-shrink: 0; }
  .subject-name { flex: 1; font-size: 0.8125rem; color: var(--fg, #fff); }
  .subject-meta { font-size: 0.75rem; color: var(--muted, #71717a); font-family: var(--font-mono, monospace); }
  .sub-nav { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .sub-nav a { font-size: 0.8rem; color: var(--muted, #71717a); text-decoration: none; }
  .sub-nav a:hover { color: #fff; }
</style>
