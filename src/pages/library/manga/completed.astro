---
/*
 * MAL API (manga completed): https://api.myanimelist.net/v2/users/chirag127/mangalist?fields=list_status,mean&status=completed&limit=500
 * Header: X-MAL-CLIENT-ID: CLIENT_ID
 */
import Layout from '~/layouts/Layout.astro'
import { getMALManga } from '~/lib/api'

const completed = await getMALManga('completed', 200)
---

<Layout title="Completed Manga" active="/library/manga/">
  <div class="page-header">
    <div class="kicker">MANGA · COMPLETED</div>
    <h1>Completed</h1>
    <p class="muted">{completed.length} volumes read</p>
  </div>
  <ol class="subject-list">
    {completed.map((m: any, i: number) => (
      <li class="subject-row">
        <span class="rank">{i + 1}</span>
        <span class="subject-name">{m.node.title}</span>
        <span class="subject-meta">{m.list_status.score > 0 ? `★ ${m.list_status.score}` : ''}</span>
      </li>
    ))}
  </ol>
</Layout>

<style>
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 { font-size: 1.5rem; margin: 0.25rem 0; }
  .subject-list { list-style: none; display: flex; flex-direction: column; gap: 2px; }
  .subject-row { display: flex; align-items: center; gap: 0.75rem; padding: 5px 8px; border-radius: 5px; }
  .subject-row:hover { background: rgba(255,255,255,0.03); }
  .rank { font-family: var(--font-mono, monospace); font-size: 0.7rem; color: var(--faint, #52525b); width: 2rem; text-align: right; flex-shrink: 0; }
  .subject-name { flex: 1; font-size: 0.8125rem; color: var(--fg, #fff); }
  .subject-meta { font-size: 0.75rem; color: var(--muted, #71717a); font-family: var(--font-mono, monospace); }
</style>
