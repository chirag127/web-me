---
import Layout from '~/layouts/Layout.astro'
import { readFileSync } from 'fs'
import { join } from 'path'

let wakatime: any = {}
let lastfmUser: any = {}
let lastfmTopArtists: any[] = []
let traktStats: any = {}
let habiticaUser: any = {}
let ghUser: any = {}
let npmPackages: any[] = []
let lbPlaying: any = null
let traktMovies: any[] = []
let fitDaily: any = {}
let togglSummary: any = {}

try { wakatime = JSON.parse(readFileSync(join(process.cwd(), 'public/data/wakatime-stats-7d.json'), 'utf-8')) } catch {}
try { lastfmUser = JSON.parse(readFileSync(join(process.cwd(), 'public/data/lastfm-user.json'), 'utf-8')) } catch {}
try { lastfmTopArtists = JSON.parse(readFileSync(join(process.cwd(), 'public/data/lastfm-top-artists.json'), 'utf-8')) } catch {}
try { traktStats = JSON.parse(readFileSync(join(process.cwd(), 'public/data/trakt-stats.json'), 'utf-8')) } catch {}
try { habiticaUser = JSON.parse(readFileSync(join(process.cwd(), 'public/data/habitica-user.json'), 'utf-8')) } catch {}
try { ghUser = JSON.parse(readFileSync(join(process.cwd(), 'public/data/github-user.json'), 'utf-8')) } catch {}
try { npmPackages = JSON.parse(readFileSync(join(process.cwd(), 'public/data/npm-packages.json'), 'utf-8')) } catch {}
try { lbPlaying = JSON.parse(readFileSync(join(process.cwd(), 'public/data/lb-playing-now.json'), 'utf-8')) } catch {}
try { traktMovies = JSON.parse(readFileSync(join(process.cwd(), 'public/data/trakt-movies-enriched.json'), 'utf-8')) } catch {}
try { fitDaily = JSON.parse(readFileSync(join(process.cwd(), 'public/data/fit-daily.json'), 'utf-8')) } catch {}
try { togglSummary = JSON.parse(readFileSync(join(process.cwd(), 'public/data/toggl-summary.json'), 'utf-8')) } catch {}

// WakaTime
const topLang = wakatime.languages?.[0]?.name || '—'
const topLangPct = wakatime.languages?.[0]?.percent || 0
const codingHours = wakatime.human_readable || '—'

// Last.fm
const scrobbles = Number(lastfmUser.playcount || 0).toLocaleString()
const topArtist = lastfmTopArtists[0]?.name || '—'
const topArtistPlays = Number(lastfmTopArtists[0]?.playcount || 0).toLocaleString()

// Trakt
const moviesWatched = traktStats.movies?.watched || 0

// GitHub
const ghRepos = ghUser.public_repos || 0

// Habitica
const habiticaLevel = habiticaUser?.data?.stats?.lvl || 0
const habiticaClass = habiticaUser?.data?.stats?.class || ''
const habiticaClassIcon: Record<string, string> = { warrior: '⚔', rogue: '🗡', mage: '✦', healer: '✚' }
const habiticaIcon = habiticaClassIcon[habiticaClass] || '⚔'
const habiticaHp = Math.round(habiticaUser?.data?.stats?.hp || 0)
const habiticaMaxHp = Math.round(habiticaUser?.data?.stats?.maxHealth || 50)

// Steps — last_7_days[-1] (most recent day)
const last7 = fitDaily.last_7_days || []
const todaySteps = last7.length > 0 ? (last7[last7.length - 1].steps || 0) : 0
const stepsDisplay = Number(todaySteps).toLocaleString()

// Toggl — total seconds from summary groups
let togglSeconds = 0
if (togglSummary.groups) {
  togglSummary.groups.forEach((g: any) => {
    g.sub_groups?.forEach((sg: any) => { togglSeconds += sg.seconds || 0 })
  })
}
const togglHours = (togglSeconds / 3600).toFixed(1)

// Top languages for bar chart (top 6)
const topLangs = (wakatime.languages || []).slice(0, 6)

// Top artists for bar chart (top 6)
const topArtistBar = lastfmTopArtists.slice(0, 6)
const maxArtistPlays = topArtistBar.length > 0 ? Number(topArtistBar[0].playcount) : 1
---

<Layout title="Dashboard" description="Live personal stats — coding, music, movies, health">

  <div class="page-updated">DATA · 2026-07-08</div>

  <div class="kicker">ME · STATS</div>
  <h1 class="page-title">Life Dashboard</h1>
  <p class="page-subtitle">Live data from all trackers.</p>

  <!-- Row 1: 4 tiles -->
  <div class="bento-row-4 animate-in">

    <!-- WakaTime hours/week -->
    <a href="/me/wakatime" class="card bento-tile bento-coding">
      <div class="tile-top">
        <span class="tile-icon" aria-hidden="true">⌨</span>
        <span class="tile-label">CODING THIS WEEK</span>
      </div>
      <div class="stat-number coding">{codingHours}</div>
      <div class="stat-label">hrs past 7 days</div>
    </a>

    <!-- Last.fm scrobbles -->
    <a href="/library/music/" class="card bento-tile bento-music">
      <div class="tile-top">
        <span class="tile-icon" aria-hidden="true">♪</span>
        <span class="tile-label">MUSIC SCROBBLES</span>
      </div>
      <div class="stat-number music">{scrobbles}</div>
      <div class="stat-label">total lifetime plays</div>
    </a>

    <!-- GitHub repos -->
    <a href="/work/open-source" class="card bento-tile bento-coding">
      <div class="tile-top">
        <span class="tile-icon" aria-hidden="true">◧</span>
        <span class="tile-label">GITHUB REPOS</span>
      </div>
      <div class="stat-number coding">{ghRepos}</div>
      <div class="stat-label">{ghUser.followers || 0} followers</div>
    </a>

    <!-- Movies watched -->
    <a href="/library/movies/" class="card bento-tile bento-social">
      <div class="tile-top">
        <span class="tile-icon" aria-hidden="true">▶</span>
        <span class="tile-label">MOVIES WATCHED</span>
      </div>
      <div class="stat-number social">{moviesWatched}</div>
      <div class="stat-label">{traktStats.movies?.minutes ? Math.round(traktStats.movies.minutes / 60) + ' hrs total' : 'all time'}</div>
    </a>

  </div>

  <!-- Row 2: 3 tiles -->
  <div class="bento-row-3 animate-in">

    <!-- Habitica level + class -->
    <a href="/me/productivity" class="card bento-tile bento-health">
      <div class="tile-top">
        <span class="tile-icon" aria-hidden="true">{habiticaIcon}</span>
        <span class="tile-label">HABITICA</span>
      </div>
      <div class="stat-number health">Lv {habiticaLevel}</div>
      <div class="stat-label">{habiticaClass || 'hero'} · {habiticaHp}/{habiticaMaxHp} HP</div>
    </a>

    <!-- Steps today -->
    <a href="/me/health" class="card bento-tile bento-health">
      <div class="tile-top">
        <span class="tile-icon" aria-hidden="true">⊛</span>
        <span class="tile-label">STEPS TODAY</span>
      </div>
      <div class="stat-number health">{stepsDisplay}</div>
      <div class="stat-label">avg {Number(fitDaily.avg_steps_last_30d || 0).toLocaleString()} / 30d</div>
    </a>

    <!-- Toggl time -->
    <a href="/me/productivity" class="card bento-tile bento-social">
      <div class="tile-top">
        <span class="tile-icon" aria-hidden="true">◷</span>
        <span class="tile-label">TOGGL TRACKED</span>
      </div>
      <div class="stat-number social">{togglHours}h</div>
      <div class="stat-label">time tracked total</div>
    </a>

  </div>

  <!-- Row 3: 2 wide tiles -->
  <div class="bento-row-2 animate-in">

    <!-- Top coding language bar -->
    <div class="card bento-wide bento-wide--coding">
      <div class="wide-header">
        <div class="kicker kicker--inline">TOP LANGUAGES · LAST 7 DAYS</div>
        <span class="wide-total">{codingHours} total</span>
      </div>
      {topLangs.length > 0 ? (
        <div class="bar-list">
          {topLangs.map((lang: any) => (
            <div class="bar-row">
              <span class="bar-name">{lang.name}</span>
              <div class="bar-track">
                <div class="bar-fill bar-fill--coding" style={`width:${lang.percent}%;background:${lang.color || '#6366f1'}`}></div>
              </div>
              <span class="bar-pct">{lang.percent?.toFixed(1)}%</span>
              <span class="bar-time">{lang.text}</span>
            </div>
          ))}
        </div>
      ) : (
        <div class="bar-empty">No coding data yet.</div>
      )}
    </div>

    <!-- Top music artist bar -->
    <div class="card bento-wide bento-wide--music">
      <div class="wide-header">
        <div class="kicker kicker--inline">TOP ARTISTS · ALL TIME</div>
        <span class="wide-total">{scrobbles} plays</span>
      </div>
      {topArtistBar.length > 0 ? (
        <div class="bar-list">
          {topArtistBar.map((artist: any) => (
            <div class="bar-row">
              <span class="bar-name">{artist.name}</span>
              <div class="bar-track">
                <div class="bar-fill bar-fill--music" style={`width:${Math.round(Number(artist.playcount) / maxArtistPlays * 100)}%`}></div>
              </div>
              <span class="bar-pct">{Number(artist.playcount).toLocaleString()}</span>
              <span class="bar-time">plays</span>
            </div>
          ))}
        </div>
      ) : (
        <div class="bar-empty">No music data yet.</div>
      )}
    </div>

  </div>

  <!-- Now playing -->
  {lbPlaying?.playing_now && (
    <section class="section-block animate-in">
      <div class="kicker">NOW PLAYING</div>
      <div class="card now-playing-card">
        <div class="np-dot"><span class="glow-dot"></span></div>
        <div class="np-info">
          <div class="np-track">{lbPlaying.track_metadata?.track_name}</div>
          <div class="np-artist">{lbPlaying.track_metadata?.artist_name} · {lbPlaying.track_metadata?.release_name}</div>
        </div>
        <span class="badge badge--emerald">LIVE</span>
      </div>
    </section>
  )}

  <!-- Last movie watched -->
  {traktMovies.length > 0 && (
    <section class="section-block animate-in">
      <div class="kicker">LAST MOVIE WATCHED</div>
      <div class="card last-movie-card">
        {traktMovies[0]._tmdb?.poster && (
          <img
            src={traktMovies[0]._tmdb.poster}
            alt={traktMovies[0].movie?.title}
            class="last-movie-poster"
            loading="lazy"
            onerror="this.parentElement.style.display='none'"
          />
        )}
        <div class="last-movie-info">
          <div class="last-movie-title">{traktMovies[0].movie?.title} <span class="last-movie-year">({traktMovies[0].movie?.year})</span></div>
          {traktMovies[0]._tmdb?.overview && (
            <p class="last-movie-overview">{traktMovies[0]._tmdb.overview.substring(0, 180)}…</p>
          )}
          <div class="last-movie-meta">
            {traktMovies[0]._tmdb?.rating && (
              <span class="last-movie-rating">★ {traktMovies[0]._tmdb.rating.toFixed(1)}</span>
            )}
            {traktMovies[0]._tmdb?.genres?.slice(0, 3).map((g: string) => (
              <span class="chip">{g}</span>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

</Layout>

<style>
  /* ── Variables ──────────────────────────────── */
  :root {
    --c-coding:  #6366f1; /* indigo */
    --c-music:   #8b5cf6; /* violet */
    --c-health:  #10b981; /* emerald */
    --c-social:  #f59e0b; /* amber */
  }

  /* ── Page header ──────────────────────────── */
  .page-updated {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--t-4);
    letter-spacing: 0.05em;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin: 0.5rem 0 0.5rem;
    background: linear-gradient(135deg, var(--c-health) 0%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .page-subtitle {
    font-size: 16px;
    color: var(--t-3);
    margin-bottom: 2rem;
  }

  .section-block { margin-top: 3rem; }

  /* ── Bento rows ───────────────────────────── */
  .bento-row-4,
  .bento-row-3,
  .bento-row-2 {
    display: grid;
    gap: 1rem;
    margin-top: 1rem;
  }

  .bento-row-4 { grid-template-columns: repeat(4, 1fr); }
  .bento-row-3 { grid-template-columns: repeat(3, 1fr); }
  .bento-row-2 { grid-template-columns: repeat(2, 1fr); }

  @media (max-width: 900px) {
    .bento-row-4 { grid-template-columns: repeat(2, 1fr); }
    .bento-row-3 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .bento-row-4,
    .bento-row-3,
    .bento-row-2 { grid-template-columns: 1fr; }
  }

  /* ── Tiles ────────────────────────────────── */
  .bento-tile {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    text-decoration: none;
    padding: 1.25rem;
    transition: border-color 120ms, transform 120ms;
  }

  .bento-tile:hover { transform: translateY(-2px); border-color: rgba(99,102,241,0.35); }

  .tile-top {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .tile-icon {
    font-size: 14px;
    line-height: 1;
  }

  .tile-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.08em;
    color: var(--t-4);
  }

  /* ── Stat number + label ──────────────────── */
  .stat-number {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 800;
    line-height: 1;
    margin-top: 0.3rem;
  }

  .stat-number.coding  { color: var(--c-coding);  }
  .stat-number.music   { color: var(--c-music);   }
  .stat-number.health  { color: var(--c-health);  }
  .stat-number.social  { color: var(--c-social);  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--t-4);
    margin-top: 2px;
  }

  /* tile accent borders */
  .bento-coding { border-left: 2px solid rgba(99,102,241,0.4); }
  .bento-music  { border-left: 2px solid rgba(139,92,246,0.4); }
  .bento-health { border-left: 2px solid rgba(16,185,129,0.4); }
  .bento-social { border-left: 2px solid rgba(245,158,11,0.4); }

  /* ── Wide tiles (Row 3) ───────────────────── */
  .bento-wide {
    padding: 1.25rem;
  }

  .wide-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .kicker--inline {
    font-size: 9px;
  }

  .wide-total {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--t-4);
  }

  .bento-wide--coding { border-left: 2px solid rgba(99,102,241,0.4); }
  .bento-wide--music  { border-left: 2px solid rgba(139,92,246,0.4); }

  /* ── Bar list ─────────────────────────────── */
  .bar-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .bar-row {
    display: grid;
    grid-template-columns: 110px 1fr 52px 70px;
    align-items: center;
    gap: 10px;
    padding: 7px 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }

  .bar-row:last-child { border-bottom: none; }

  .bar-name {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--t-2);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bar-track {
    height: 4px;
    background: rgba(255,255,255,0.06);
    border-radius: 2px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 400ms ease;
  }

  .bar-fill--coding { background: var(--c-coding); }
  .bar-fill--music  { background: var(--c-music);  }

  .bar-pct {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--t-3);
    text-align: right;
  }

  .bar-time {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--t-4);
    text-align: right;
  }

  .bar-empty {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--t-4);
    padding: 1rem 0;
  }

  /* ── Now playing ──────────────────────────── */
  .now-playing-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
  }

  .np-dot { flex-shrink: 0; }

  .np-info { flex: 1; min-width: 0; }

  .np-track {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    color: var(--t-1);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .np-artist {
    font-size: 12px;
    color: var(--t-3);
    margin-top: 2px;
  }

  /* ── Last movie ───────────────────────────── */
  .last-movie-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-top: 1rem;
  }

  .last-movie-poster {
    width: 64px;
    height: 96px;
    border-radius: 6px;
    object-fit: cover;
    flex-shrink: 0;
    border: 1px solid var(--border);
  }

  .last-movie-info { flex: 1; min-width: 0; }

  .last-movie-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    color: var(--t-1);
    margin-bottom: 6px;
  }

  .last-movie-year { color: var(--t-4); font-size: 13px; font-weight: 400; }

  .last-movie-overview {
    font-size: 12px;
    color: var(--t-3);
    line-height: 1.5;
    margin-bottom: 8px;
  }

  .last-movie-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .last-movie-rating {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--c-social);
    font-weight: 600;
  }

  /* ── Animation ────────────────────────────── */
  .animate-in {
    animation: fadeUp 0.4s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
