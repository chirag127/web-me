---
import Layout from '~/layouts/Layout.astro'
import { readFileSync } from 'fs'
import { join } from 'path'

let fit: any = {}
try { fit = JSON.parse(readFileSync(join(process.cwd(), 'public/data/fit-daily.json'), 'utf-8')) } catch {}

const totalDays: number = fit.total_days || 0
const avgSteps30d: number = fit.avg_steps_last_30d || 0
const totalKm: number = fit.total_distance_km || 0
const avgStepsAll: number = fit.avg_steps_all_time || 0
const last7: any[] = fit.last_7_days || []
const last30: any[] = fit.last_30_days || []
const dateRange = fit.date_range || {}

const max7Steps = last7.length ? Math.max(...last7.map((d: any) => d.steps), 1) : 1
const max30Steps = last30.length ? Math.max(...last30.map((d: any) => d.steps), 1) : 1

function fmtDate(d: string): string {
  if (!d) return ''
  const parts = d.split('-')
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']
  return `${months[parseInt(parts[1])-1]} ${parseInt(parts[2])}`
}

function fmtSteps(n: number): string {
  return n >= 1000 ? `${(n/1000).toFixed(1)}k` : String(n)
}
---

<Layout title="Health" description="Fitness data tracked since April 2023 via Google Fit Takeout.">

  <div class="kicker">ME · HEALTH</div>
  <h1 class="page-title">Health</h1>
  <p class="page-subtitle">Fitness data from Google Fit via Takeout.</p>

  {totalDays === 0 ? (
    <div class="card empty-state">
      <p>No fitness data yet. Run the Takeout workflow to populate.</p>
    </div>
  ) : (
    <>
      <!-- Stats row -->
      <div class="stats-row animate-in">
        <div class="card stat-card">
          <div class="stat-number">{totalDays.toLocaleString()}</div>
          <div class="stat-label">DAYS TRACKED</div>
        </div>
        <div class="card stat-card">
          <div class="stat-number">{avgSteps30d.toLocaleString()}</div>
          <div class="stat-label">AVG STEPS (30D)</div>
        </div>
        <div class="card stat-card">
          <div class="stat-number">{totalKm.toLocaleString()}</div>
          <div class="stat-label">KM WALKED TOTAL</div>
        </div>
        <div class="card stat-card">
          <div class="stat-number">{avgStepsAll.toLocaleString()}</div>
          <div class="stat-label">AVG STEPS (ALL TIME)</div>
        </div>
      </div>

      <!-- Date range badge -->
      {dateRange.start && (
        <div class="date-range animate-in">
          {dateRange.start} → {dateRange.end}
        </div>
      )}

      <!-- Last 7 days bar chart -->
      {last7.length > 0 && (
        <section class="section-block animate-in">
          <div class="kicker">LAST 7 DAYS — STEPS</div>
          <div class="card bar-chart-card">
            {last7.map((day: any) => (
              <div class="bar-col">
                <div class="bar-steps-label">{fmtSteps(day.steps)}</div>
                <div class="bar-track">
                  <div
                    class="bar-fill"
                    style={`height:${Math.max(4, Math.round((day.steps / max7Steps) * 100))}%`}
                  ></div>
                </div>
                <div class="bar-date">{fmtDate(day.date)}</div>
                {day.heart_rate_avg && (
                  <div class="bar-hr">♥ {Math.round(parseFloat(day.heart_rate_avg))}</div>
                )}
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Last 30 days sparkline -->
      {last30.length > 0 && (
        <section class="section-block animate-in">
          <div class="kicker">LAST 30 DAYS — STEP TREND</div>
          <div class="card sparkline-card">
            <div class="sparkline-row">
              {last30.map((day: any) => (
                <div class="spark-col" title={`${day.date}: ${day.steps} steps`}>
                  <div
                    class="spark-bar"
                    style={`height:${Math.max(2, Math.round((day.steps / max30Steps) * 48))}px`}
                  ></div>
                </div>
              ))}
            </div>
            <div class="sparkline-legend">
              <span>{fmtDate(last30[0]?.date)}</span>
              <span>max {max30Steps.toLocaleString()} steps</span>
              <span>{fmtDate(last30[last30.length-1]?.date)}</span>
            </div>
          </div>
        </section>
      )}
    </>
  )}

</Layout>

<style>
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: var(--t-1);
    margin: 0.5rem 0;
    background: linear-gradient(135deg, #10b981 0%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .page-subtitle {
    font-size: 16px;
    color: var(--t-3);
    margin-bottom: 2rem;
  }

  .date-range {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--t-4);
    letter-spacing: 0.06em;
    margin: -1rem 0 1.5rem;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 800;
    color: #10b981;
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.08em;
    color: var(--t-4);
  }

  .section-block {
    margin-top: 2.5rem;
  }

  /* 7-day bar chart */
  .bar-chart-card {
    display: flex;
    gap: 8px;
    align-items: flex-end;
    padding: 16px;
    margin-top: 1rem;
    overflow-x: auto;
  }

  .bar-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    flex: 1;
    min-width: 40px;
  }

  .bar-steps-label {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--t-3);
  }

  .bar-track {
    width: 100%;
    height: 80px;
    background: rgba(255,255,255,0.05);
    border-radius: 3px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .bar-fill {
    width: 100%;
    background: #10b981;
    border-radius: 3px 3px 0 0;
    transition: height 400ms ease;
    min-height: 4px;
  }

  .bar-date {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--t-4);
    white-space: nowrap;
  }

  .bar-hr {
    font-family: var(--font-mono);
    font-size: 9px;
    color: #f43f5e;
  }

  /* 30-day sparkline */
  .sparkline-card {
    margin-top: 1rem;
    padding: 16px;
  }

  .sparkline-row {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 52px;
  }

  .spark-col {
    flex: 1;
    display: flex;
    align-items: flex-end;
    min-width: 4px;
  }

  .spark-bar {
    width: 100%;
    background: #10b981;
    border-radius: 1px 1px 0 0;
    opacity: 0.8;
    min-height: 2px;
    transition: height 300ms ease;
  }

  .spark-bar:hover {
    opacity: 1;
    background: #34d399;
  }

  .sparkline-legend {
    display: flex;
    justify-content: space-between;
    margin-top: 8px;
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--t-4);
  }

  .empty-state {
    color: var(--t-3);
    font-size: 14px;
    text-align: center;
    padding: 2rem;
  }

  .animate-in {
    animation: fadeUp 0.4s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
