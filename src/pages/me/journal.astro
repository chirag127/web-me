---
import Layout from '~/layouts/Layout.astro'
import { readFileSync } from 'fs'
import { join } from 'path'

let entries: any[] = []
let stats: any = { total: 0, moods: {}, last_entry: '' }

try { entries = JSON.parse(readFileSync(join(process.cwd(), 'public/data/notion-journal.json'), 'utf-8')) } catch {}
try { stats   = JSON.parse(readFileSync(join(process.cwd(), 'public/data/notion-stats.json'), 'utf-8')) } catch {}

// Emoji-keyed mood colors (MD3 token names)
const moodMeta: Record<string, { color: string; bg: string; label: string }> = {
  '😊': { color: '#059669', bg: '#d1fae5', label: 'Happy' },
  '😐': { color: '#d97706', bg: '#fef3c7', label: 'Okay' },
  '😞': { color: '#e11d48', bg: '#ffe4e6', label: 'Sad' },
  '😤': { color: '#dc2626', bg: '#fee2e2', label: 'Frustrated' },
  '😴': { color: '#64748b', bg: '#f1f5f9', label: 'Tired' },
}

function moodStyle(mood: string) {
  const m = moodMeta[mood]
  if (!m) return { color: '#6366f1', bg: '#eef2ff' }
  return m
}

const moodEntries: [string, number][] = Object.entries(stats.moods ?? {})
  .sort((a, b) => (b[1] as number) - (a[1] as number)) as [string, number][]

const hasData = entries.length > 0
---

<Layout title="Journal" description="Daily logs via Notion — mood, energy, and notes.">
  <div class="journal-root">

    <p class="kicker">ME · JOURNAL</p>
    <h1>Journal</h1>
    <p class="subtitle">Daily logs via Notion.</p>

    {!hasData ? (
      <div class="setup-card">
        <div class="setup-icon" aria-hidden="true">📓</div>
        <h2 class="setup-title">Connect your Notion journal</h2>
        <p class="setup-desc">No entries yet. Share your Notion database with the integration:</p>
        <ol class="setup-steps">
          <li>Open your Notion page → click <kbd>···</kbd> (top right) → <strong>Connections</strong> → add the <strong>all</strong> integration</li>
          <li>Data appears here after the next daily refresh</li>
        </ol>
        <a class="setup-link" href="https://app.notion.com" target="_blank" rel="noopener">
          Open app.notion.com →
        </a>
      </div>
    ) : (
      <>
        <div class="stats-row">
          <div class="stat-card">
            <div class="stat-value">{stats.total}</div>
            <div class="stat-label">ENTRIES</div>
          </div>
          {stats.last_entry && (
            <div class="stat-card">
              <div class="stat-value mono">{stats.last_entry}</div>
              <div class="stat-label">LAST ENTRY</div>
            </div>
          )}
          {moodEntries.length > 0 && (
            <div class="stat-card mood-breakdown">
              <div class="stat-label">MOOD BREAKDOWN</div>
              <div class="chip-row">
                {moodEntries.map(([mood, count]) => {
                  const s = moodStyle(mood)
                  return (
                    <span class="chip" style={`background:${s.bg};color:${s.color}`}>
                      {mood} <span class="chip-count">{count}</span>
                    </span>
                  )
                })}
              </div>
            </div>
          )}
        </div>

        <div class="entries-list">
          {entries.map((e: any) => {
            const ms = e.mood ? moodStyle(e.mood) : null
            const preview = e.notes ? e.notes.slice(0, 120) + (e.notes.length > 120 ? '…' : '') : null
            return (
              <div class="entry-card">
                <div class="entry-header">
                  <span class="entry-date mono">{e.date}</span>
                  {e.mood && ms && (
                    <span class="mood-badge" style={`background:${ms.bg};color:${ms.color}`}>
                      {e.mood}
                    </span>
                  )}
                  {e.energy && <span class="energy-chip">{e.energy}</span>}
                </div>
                {e.title && <div class="entry-title">{e.title}</div>}
                {e.tags?.length > 0 && (
                  <div class="chip-row">
                    {e.tags.map((t: string) => <span class="chip">{t}</span>)}
                  </div>
                )}
                {preview && <p class="entry-notes">{preview}</p>}
                {e.url && (
                  <a href={e.url} target="_blank" rel="noopener" class="entry-link">Open in Notion →</a>
                )}
              </div>
            )
          })}
        </div>
      </>
    )}

  </div>
</Layout>

<style>
  .journal-root {
    padding-top: 2rem;
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .kicker {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--indigo);
    text-transform: uppercase;
    margin: 0;
  }

  h1 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 2rem;
    color: var(--t-1);
    margin: 0;
  }

  .subtitle {
    font-size: 15px;
    color: var(--t-2);
    margin: 0;
  }

  /* Setup card */
  .setup-card {
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  .setup-icon {
    font-size: 2rem;
  }

  .setup-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--t-1);
    margin: 0;
  }

  .setup-desc {
    font-size: 14px;
    color: var(--t-2);
    margin: 0;
  }

  .setup-steps {
    font-size: 14px;
    color: var(--t-2);
    margin: 0;
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .setup-steps li {
    line-height: 1.6;
  }

  kbd {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 5px;
    font-size: 12px;
    font-family: var(--font-mono, monospace);
  }

  .setup-link {
    font-size: 13px;
    font-weight: 600;
    color: var(--indigo);
    text-decoration: none;
    margin-top: 4px;
  }

  .setup-link:hover { text-decoration: underline; }

  /* Stats row */
  .stats-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .stat-card {
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 18px;
    min-width: 120px;
  }

  .stat-value {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.5rem;
    color: var(--t-1);
    line-height: 1.2;
  }

  .stat-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--t-3);
    text-transform: uppercase;
    margin-top: 4px;
  }

  .mood-breakdown { flex: 1; }

  /* Chips */
  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 6px;
  }

  .chip {
    font-size: 11px;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 20px;
    background: var(--surface-2);
    color: var(--t-3);
  }

  .chip-count {
    opacity: 0.75;
    font-weight: 400;
    margin-left: 2px;
  }

  /* Entry list */
  .entries-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .entry-card {
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: border-color 0.2s;
  }

  .entry-card:hover { border-color: var(--indigo); }

  .entry-header {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .entry-date {
    font-size: 13px;
    color: var(--t-3);
  }

  .mono { font-family: var(--font-mono, monospace); }

  .mood-badge {
    font-size: 13px;
    padding: 2px 8px;
    border-radius: 20px;
    font-weight: 600;
  }

  .energy-chip {
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 20px;
    background: var(--surface-2);
    color: var(--t-2);
  }

  .entry-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--t-1);
  }

  .entry-notes {
    font-size: 13px;
    color: var(--t-2);
    line-height: 1.6;
    margin: 0;
  }

  .entry-link {
    font-size: 12px;
    color: var(--indigo);
    text-decoration: none;
    align-self: flex-start;
  }

  .entry-link:hover { text-decoration: underline; }
</style>
