---
import Layout from '~/layouts/Layout.astro'
---
<Layout title="About" description="Chirag Singhal — software engineer, full stack and distributed systems specialist." active="/about/">

  <!-- Header -->
  <header style="margin-bottom:2.5rem">
    <span class="kicker">About</span>
    <h1 style="font-family:var(--font-display);font-size:2rem;font-weight:600;letter-spacing:-0.02em;color:var(--fg);margin:0 0 1.25rem">Chirag Singhal</h1>
    <p style="font-family:Charter,'Bitstream Charter',Cambria,Georgia,serif;color:var(--muted);line-height:1.7;max-width:60ch;margin:0">
      Software engineer at TCS in Bhubaneswar, India, specialising in full-stack, backend, and distributed systems. I build the <strong style="color:var(--fg)">chirag127 family</strong> — 20+ free tools, sites, and APIs — with zero cards on file, one commit at a time.
    </p>
  </header>

  <!-- Education -->
  <section style="margin-bottom:3rem">
    <div class="section-title">
      <span class="kicker">Education</span>
    </div>

    <!-- Timeline -->
    <div style="display:flex;flex-direction:column;gap:0;border-left:1px solid var(--rule);margin-left:0.375rem">

      <div style="position:relative;padding:0 0 2rem 1.5rem">
        <span style="position:absolute;left:-0.4375rem;top:0.35rem;width:0.5rem;height:0.5rem;border-radius:50%;background:var(--accent);flex-shrink:0"></span>
        <div style="display:flex;align-items:baseline;gap:0.75rem;flex-wrap:wrap;margin-bottom:0.25rem">
          <span style="font-family:var(--font-display);font-size:1rem;font-weight:600;letter-spacing:-0.01em;color:var(--fg)">B.Tech, Computer Science &amp; Engineering</span>
          <span style="font-family:var(--font-ui);font-size:0.72rem;color:var(--faint)">2020 – 2024</span>
        </div>
        <div style="font-family:var(--font-ui);font-size:0.8rem;color:var(--accent);margin-bottom:0.35rem">AKTU — Dr. A.P.J. Abdul Kalam Technical University</div>
        <p style="font-family:Charter,'Bitstream Charter',Cambria,Georgia,serif;font-size:0.9rem;color:var(--muted);max-width:60ch;margin:0">
          CGPA 8.81 · <strong style="color:var(--fg)">College Topper, Rank 1</strong> in CSE Batch 2020–2024.
        </p>
      </div>

      <div style="position:relative;padding:0 0 0 1.5rem">
        <span style="position:absolute;left:-0.4375rem;top:0.35rem;width:0.5rem;height:0.5rem;border-radius:50%;background:var(--faint);flex-shrink:0"></span>
        <div style="display:flex;align-items:baseline;gap:0.75rem;flex-wrap:wrap;margin-bottom:0.25rem">
          <span style="font-family:var(--font-display);font-size:1rem;font-weight:600;letter-spacing:-0.01em;color:var(--fg)">Class 12 — Science (CBSE)</span>
          <span style="font-family:var(--font-ui);font-size:0.72rem;color:var(--faint)">2020</span>
        </div>
        <div style="font-family:var(--font-ui);font-size:0.8rem;color:var(--accent);margin-bottom:0.35rem">DDPS — Delhi Public School, Patna</div>
        <p style="font-family:Charter,'Bitstream Charter',Cambria,Georgia,serif;font-size:0.9rem;color:var(--muted);max-width:60ch;margin:0">
          97% · <strong style="color:var(--fg)">School Topper</strong> · IIT JEE Advanced AIR 11870 (Top 1%, 99th percentile).
        </p>
      </div>

    </div>
  </section>

  <!-- Honors & Achievements -->
  <section style="margin-bottom:3rem">
    <div class="section-title">
      <span class="kicker">Honors &amp; Achievements</span>
    </div>

    <ul style="list-style:none;display:flex;flex-direction:column;gap:0.75rem;max-width:60ch">
      <li style="display:flex;align-items:baseline;gap:1rem">
        <span style="font-family:var(--font-ui);font-size:0.72rem;color:var(--faint);flex-shrink:0;width:2.5rem">2024</span>
        <span style="font-family:Charter,'Bitstream Charter',Cambria,Georgia,serif;font-size:0.95rem;color:var(--fg)">College Topper — Rank 1 in CSE Batch, AKTU</span>
      </li>
      <li style="display:flex;align-items:baseline;gap:1rem">
        <span style="font-family:var(--font-ui);font-size:0.72rem;color:var(--faint);flex-shrink:0;width:2.5rem">2025</span>
        <span style="font-family:Charter,'Bitstream Charter',Cambria,Georgia,serif;font-size:0.95rem;color:var(--fg)">AWS Certified Developer — Associate</span>
      </li>
      <li style="display:flex;align-items:baseline;gap:1rem">
        <span style="font-family:var(--font-ui);font-size:0.72rem;color:var(--faint);flex-shrink:0;width:2.5rem">2023</span>
        <span style="font-family:Charter,'Bitstream Charter',Cambria,Georgia,serif;font-size:0.95rem;color:var(--fg)">Meta Backend Developer Certification (Coursera)</span>
      </li>
      <li style="display:flex;align-items:baseline;gap:1rem">
        <span style="font-family:var(--font-ui);font-size:0.72rem;color:var(--faint);flex-shrink:0;width:2.5rem">2020</span>
        <span style="font-family:Charter,'Bitstream Charter',Cambria,Georgia,serif;font-size:0.95rem;color:var(--fg)">JEE Advanced AIR 11870 — 99th percentile, Top 1%</span>
      </li>
    </ul>
  </section>

  <!-- Elsewhere -->
  <section>
    <div class="section-title">
      <span class="kicker">Elsewhere</span>
    </div>

    <dl style="display:grid;grid-template-columns:auto 1fr;gap:0.5rem 1.5rem;max-width:60ch">
      <dt style="font-family:var(--font-ui);font-size:0.75rem;color:var(--faint);align-self:center">GitHub</dt>
      <dd style="margin:0">
        <a href="https://github.com/chirag127" target="_blank" rel="noopener noreferrer"
           style="font-family:Charter,'Bitstream Charter',Cambria,Georgia,serif;font-size:0.95rem;color:var(--accent);text-underline-offset:0.2em;text-decoration-thickness:1px">
          github.com/chirag127
        </a>
      </dd>

      <dt style="font-family:var(--font-ui);font-size:0.75rem;color:var(--faint);align-self:center">LinkedIn</dt>
      <dd style="margin:0">
        <a href="https://linkedin.com/in/chirag127" target="_blank" rel="noopener noreferrer"
           style="font-family:Charter,'Bitstream Charter',Cambria,Georgia,serif;font-size:0.95rem;color:var(--accent);text-underline-offset:0.2em;text-decoration-thickness:1px">
          linkedin.com/in/chirag127
        </a>
      </dd>

      <dt style="font-family:var(--font-ui);font-size:0.75rem;color:var(--faint);align-self:center">Email</dt>
      <dd style="margin:0">
        <a href="mailto:hi@chirag127.in"
           style="font-family:Charter,'Bitstream Charter',Cambria,Georgia,serif;font-size:0.95rem;color:var(--accent);text-underline-offset:0.2em;text-decoration-thickness:1px">
          hi@chirag127.in
        </a>
      </dd>

      <dt style="font-family:var(--font-ui);font-size:0.75rem;color:var(--faint);align-self:center">Last.fm</dt>
      <dd style="margin:0">
        <a href="https://www.last.fm/user/chirag127" target="_blank" rel="noopener noreferrer"
           style="font-family:Charter,'Bitstream Charter',Cambria,Georgia,serif;font-size:0.95rem;color:var(--accent);text-underline-offset:0.2em;text-decoration-thickness:1px">
          last.fm/user/chirag127
        </a>
      </dd>

      <dt style="font-family:var(--font-ui);font-size:0.75rem;color:var(--faint);align-self:center">Tools</dt>
      <dd style="margin:0">
        <a href="https://oriz.in" target="_blank" rel="noopener noreferrer"
           style="font-family:Charter,'Bitstream Charter',Cambria,Georgia,serif;font-size:0.95rem;color:var(--accent);text-underline-offset:0.2em;text-decoration-thickness:1px">
          oriz.in
        </a>
      </dd>
    </dl>
  </section>

</Layout>
