---
import Layout from '~/layouts/Layout.astro'
---
<Layout title="Contact" description="Chirag Singhal — contact form">
  <div style="padding-top: 2rem; max-width: 480px;">
    <h1 class="page-title">Contact</h1>
    <p class="page-sub">Send a message. I typically respond within 24h.</p>

    <form
      action="https://api.web3forms.com/submit"
      method="POST"
      style="display:flex;flex-direction:column;gap:12px;margin-top:1.5rem;"
    >
      <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
      <input type="hidden" name="subject" value="Message from me.oriz.in" />
      <input type="hidden" name="redirect" value="https://me.oriz.in/connect/contact?success=1" />

      <div>
        <label style="display:block;font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:0.06em;color:var(--t-muted);margin-bottom:4px;">Name</label>
        <input name="name" required placeholder="Your name" style="width:100%;height:36px;background:var(--overlay);border:1px solid var(--border);border-radius:6px;padding:0 12px;font-size:13px;color:#fff;font-family:var(--font-sans);outline:none;" />
      </div>

      <div>
        <label style="display:block;font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:0.06em;color:var(--t-muted);margin-bottom:4px;">Email</label>
        <input name="email" type="email" required placeholder="you@example.com" style="width:100%;height:36px;background:var(--overlay);border:1px solid var(--border);border-radius:6px;padding:0 12px;font-size:13px;color:#fff;font-family:var(--font-sans);outline:none;" />
      </div>

      <div>
        <label style="display:block;font-size:11px;font-weight:500;text-transform:uppercase;letter-spacing:0.06em;color:var(--t-muted);margin-bottom:4px;">Message</label>
        <textarea name="message" required rows="5" placeholder="What's on your mind?" style="width:100%;background:var(--overlay);border:1px solid var(--border);border-radius:6px;padding:8px 12px;font-size:13px;color:#fff;font-family:var(--font-sans);outline:none;resize:vertical;"></textarea>
      </div>

      <div>
        <button type="submit" style="background:rgba(99,102,241,0.12);border:1px solid rgba(99,102,241,0.25);border-radius:6px;padding:8px 20px;font-size:13px;font-weight:600;color:#818cf8;cursor:pointer;">Send Message →</button>
      </div>
    </form>

    {Astro.url.searchParams.get('success') && (
      <div style="margin-top:1rem;padding:10px 14px;border-radius:8px;background:rgba(99,102,241,0.08);border:1px solid rgba(99,102,241,0.2);font-size:13px;color:#818cf8;">
        Message sent! I'll get back to you soon.
      </div>
    )}
  </div>
</Layout>
