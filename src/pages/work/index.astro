---
import Layout from '~/layouts/Layout.astro'
---
<Layout title="Work" description="Chirag Singhal — software engineering career, projects and skills">
  <div style="padding-top: 2rem; max-width: 640px;">
    <h1 class="page-title">Work</h1>
    <p class="page-sub">Software engineering career, projects, and skills overview.</p>

    <!-- Current role card -->
    <div class="glass-card" style="padding: 16px; margin-bottom: 1.5rem;">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
        <span class="pulse-dot"></span>
        <span style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:#818cf8;">Current</span>
      </div>
      <div style="font-family:var(--font-display);font-weight:600;font-size:15px;color:#fff;">Software Engineer</div>
      <div style="font-size:13px;color:var(--t-secondary);margin-top:2px;">Tata Consultancy Services · Jun 2025 – Present</div>
      <p style="font-size:12px;color:var(--t-tertiary);margin-top:8px;">Python pricing engines (60% latency reduction), CI/CD pipelines, React.js UI.</p>
    </div>

    <!-- Quick stats -->
    <div style="display:flex;gap:24px;margin-bottom:1.5rem;padding:12px 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border);">
      {[['2+','Years Exp'],['6','Projects'],['15+','Technologies']].map(([v,l],i) => (
        <>
          <div>
            <div style="font-family:var(--font-display);font-weight:700;font-size:1.5rem;color:#fff;line-height:1;">{v}</div>
            <div style="font-size:10px;text-transform:uppercase;letter-spacing:0.08em;color:var(--t-muted);margin-top:2px;">{l}</div>
          </div>
          {i < 2 && <div style="width:1px;background:var(--border);"></div>}
        </>
      ))}
    </div>

    <!-- Page links -->
    <div style="display:flex;flex-direction:column;gap:4px;">
      {[
        { href: '/work/career',         label: 'Career',          desc: 'TCS + QRsay timeline' },
        { href: '/work/projects',       label: 'Projects',        desc: '6 flagship projects' },
        { href: '/work/skills',         label: 'Skills',          desc: 'Tech stack by category' },
        { href: '/work/education',      label: 'Education',       desc: 'AKTU + CBSE' },
        { href: '/work/certifications', label: 'Certifications',  desc: 'Meta + AWS' },
      ].map(l => (
        <a href={l.href} style="display:flex;align-items:center;justify-content:space-between;height:40px;padding:0 12px;border-radius:6px;border:1px solid var(--border);background:var(--surface);text-decoration:none;">
          <span style="font-size:13px;color:#fff;">{l.label}</span>
          <span style="font-size:12px;color:var(--t-muted);">{l.desc} →</span>
        </a>
      ))}
    </div>
  </div>
</Layout>
