---
import Layout from '~/layouts/Layout.astro'
---

<Layout title="Work" description="Work history — Chirag Singhal, Software Engineer." active="/work/">

  <!-- Page header -->
  <div style="margin-bottom:2.5rem">
    <span class="kicker">EXPERIENCE</span>
    <h1>Work</h1>
  </div>

  <!-- Timeline -->
  <section style="margin-bottom:3rem">
    <div class="timeline">

      <!-- Entry 1: TCS -->
      <div class="timeline-entry">
        <div class="timeline-date">
          <span class="date-range">Jun 2025</span>
          <span class="date-range date-present">Present</span>
        </div>
        <div class="timeline-body">
          <div class="timeline-connector">
            <div class="timeline-dot"></div>
            <div class="timeline-line"></div>
          </div>
          <div class="timeline-content">
            <div style="margin-bottom:0.75rem">
              <p style="font-family:var(--font-display);font-size:1.1rem;font-weight:600;letter-spacing:-0.02em;color:var(--fg);margin:0 0 0.2rem">Software Engineer</p>
              <p style="font-family:var(--font-ui);font-size:0.8rem;color:var(--accent);margin:0">Tata Consultancy Services (TCS)</p>
            </div>
            <ul class="bullet-list">
              <li>Optimized enterprise pricing engines in Python — 60% latency reduction.</li>
              <li>Architected modular data validation pipelines via RESTful APIs.</li>
              <li>Automated CI/CD workflows, reducing production bugs across deployments.</li>
              <li>Built React.js UI for real-time backend configuration visibility.</li>
              <li>Refactored monolithic legacy codebases into OOP modules.</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Entry 2: QRsay -->
      <div class="timeline-entry">
        <div class="timeline-date">
          <span class="date-range">Jul 2023</span>
          <span class="date-range">May 2025</span>
        </div>
        <div class="timeline-body">
          <div class="timeline-connector">
            <div class="timeline-dot"></div>
          </div>
          <div class="timeline-content">
            <div style="margin-bottom:0.75rem">
              <p style="font-family:var(--font-display);font-size:1.1rem;font-weight:600;letter-spacing:-0.02em;color:var(--fg);margin:0 0 0.2rem">Software Developer — Full Stack</p>
              <p style="font-family:var(--font-ui);font-size:0.8rem;color:var(--accent);margin:0">QRsay.com</p>
            </div>
            <ul class="bullet-list">
              <li>Full SDLC ownership of high-traffic Food E-commerce platform (Python, Node.js, MongoDB).</li>
              <li>40% reduction in API response times via DB tuning and indexing.</li>
              <li>Real-time order processing with Kafka event-driven architecture.</li>
              <li>Integrated secure payment gateways end-to-end.</li>
              <li>Built modular React.js frontend components across the platform.</li>
            </ul>
          </div>
        </div>
      </div>

    </div>
  </section>

  <hr />

  <!-- Open to -->
  <section style="padding-top:0.5rem">
    <span class="kicker">OPEN TO</span>
    <p style="font-family:var(--font-body);font-size:1rem;color:var(--fg);line-height:1.65;max-width:60ch">
      Open to full-time roles, remote or hybrid, in backend&nbsp;/ full-stack&nbsp;/ AI engineering.
    </p>
    <p style="margin-top:1rem;font-family:var(--font-ui);font-size:0.8rem;color:var(--muted)">
      <a href="mailto:hi@chirag127.in" style="color:var(--accent);text-underline-offset:0.2em;text-decoration-thickness:1px">hi@chirag127.in</a>
      <span style="margin:0 0.5rem;color:var(--faint)">·</span>
      <a href="https://github.com/chirag127" target="_blank" rel="noopener noreferrer" style="color:var(--accent);text-underline-offset:0.2em;text-decoration-thickness:1px">github.com/chirag127</a>
      <span style="margin:0 0.5rem;color:var(--faint)">·</span>
      <a href="https://linkedin.com/in/chirag127" target="_blank" rel="noopener noreferrer" style="color:var(--accent);text-underline-offset:0.2em;text-decoration-thickness:1px">linkedin.com/in/chirag127</a>
    </p>
  </section>

</Layout>

<style>
.timeline {
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
}

.timeline-entry {
  display: grid;
  grid-template-columns: 6rem 1fr;
  gap: 1.5rem;
}

.timeline-date {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  padding-top: 0.15rem;
  gap: 0.1rem;
  flex-shrink: 0;
}

.date-range {
  font-family: var(--font-ui);
  font-size: 0.72rem;
  color: var(--muted);
  white-space: nowrap;
  line-height: 1.4;
}

.date-present {
  color: var(--accent);
}

.timeline-body {
  display: flex;
  gap: 1rem;
}

.timeline-connector {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  padding-top: 0.35rem;
}

.timeline-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
}

.timeline-line {
  width: 1px;
  flex: 1;
  background: var(--rule);
  margin-top: 6px;
}

.timeline-content {
  flex: 1;
  min-width: 0;
  padding-bottom: 0.5rem;
}

.bullet-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  max-width: 60ch;
}

.bullet-list li {
  font-family: var(--font-body);
  font-size: 0.9375rem;
  color: var(--muted);
  line-height: 1.6;
  padding-left: 1rem;
  position: relative;
}

.bullet-list li::before {
  content: '–';
  position: absolute;
  left: 0;
  color: var(--faint);
}

@media (max-width: 768px) {
  .timeline-entry {
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }

  .timeline-date {
    align-items: flex-start;
    flex-direction: row;
    gap: 0.5rem;
  }

  .timeline-body {
    gap: 0.75rem;
  }
}
</style>
