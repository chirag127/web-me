---
import Layout from '~/layouts/Layout.astro'
import { readFileSync } from 'fs'
import { join } from 'path'

let posts: any[] = []
try { posts = JSON.parse(readFileSync(join(process.cwd(), 'public/data/blog-posts.json'), 'utf-8')) } catch {}

let devtoArticles: any[] = []
try { devtoArticles = JSON.parse(readFileSync(join(process.cwd(), 'public/data/devto-articles.json'), 'utf-8')) } catch {}

function formatDate(dateStr: string): string {
  if (!dateStr) return ''
  try {
    return new Date(dateStr).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  } catch { return dateStr }
}
---

<Layout title="Writing" description="Technical articles on engineering and AI by Chirag Singhal">

  <div class="page-updated">DATA · 2026-07-08</div>

  <div class="kicker">WORK · WRITING</div>
  <h1 class="page-title">Writing</h1>
  <p class="page-subtitle">
    Technical articles on engineering and AI.
    <a href="https://blog.oriz.in" target="_blank" rel="noopener" class="blog-link">blog.oriz.in ↗</a>
  </p>

  {posts.length === 0 ? (
    <div class="card empty-state animate-in">
      <div class="empty-icon">▣</div>
      <div class="empty-title">No posts yet</div>
      <p class="empty-desc">Writing in progress. Check back soon or visit <a href="https://blog.oriz.in" target="_blank" rel="noopener" class="blog-link">blog.oriz.in</a>.</p>
    </div>
  ) : (
    <div class="posts-grid animate-in">
      {posts.map((post: any) => (
        <a href={post.link} target="_blank" rel="noopener" class="card post-card">
          <div class="post-meta">
            <span class="post-date">{formatDate(post.date)}</span>
          </div>
          <h2 class="post-title">{post.title}</h2>
          {post.desc && <p class="post-desc">{post.desc}</p>}
          <span class="post-cta">Read →</span>
        </a>
      ))}
    </div>
  )}

  {devtoArticles.length > 0 && (
    <div class="section-divider animate-in">
      <div class="section-label">FROM DEV.TO</div>
      <a href="https://dev.to/chirag127" target="_blank" rel="noopener" class="blog-link">dev.to/chirag127 ↗</a>
    </div>
  )}

  {devtoArticles.length > 0 && (
    <div class="posts-grid animate-in">
      {devtoArticles.map((article: any) => (
        <a href={article.url} target="_blank" rel="noopener" class="card post-card devto-card">
          {article.cover_image && (
            <img src={article.cover_image} alt={article.title} class="cover-img" loading="lazy" />
          )}
          <div class="post-meta">
            <span class="post-date">{formatDate(article.published_at)}</span>
            <span class="devto-badge">DEV</span>
          </div>
          <h2 class="post-title">{article.title}</h2>
          {article.description && <p class="post-desc">{article.description}</p>}
          {article.tag_list && article.tag_list.length > 0 && (
            <div class="tag-chips">
              {article.tag_list.slice(0, 4).map((tag: string) => (
                <span class="tag-chip">#{tag}</span>
              ))}
            </div>
          )}
          <div class="post-stats">
            {article.public_reactions_count > 0 && (
              <span class="stat">♥ {article.public_reactions_count}</span>
            )}
            {article.reading_time_minutes > 0 && (
              <span class="stat">{article.reading_time_minutes} min read</span>
            )}
            {article.comments_count > 0 && (
              <span class="stat">💬 {article.comments_count}</span>
            )}
          </div>
        </a>
      ))}
    </div>
  )}

</Layout>

<style>
  .page-updated {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--t-4);
    letter-spacing: 0.05em;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: var(--t-1);
    margin: 0.5rem 0 0.5rem;
    background: linear-gradient(135deg, var(--indigo) 0%, #a78bfa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .page-subtitle {
    font-size: 16px;
    color: var(--t-3);
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .blog-link {
    color: var(--indigo);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
  }

  .blog-link:hover {
    color: #818cf8;
  }

  /* Posts */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    transition: border-color 120ms, background 80ms;
  }

  .post-card:hover {
    border-color: rgba(99,102,241,0.3);
    background: rgba(255,255,255,0.03);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--t-4);
  }

  .post-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    color: var(--t-1);
    line-height: 1.4;
  }

  .post-desc {
    font-size: 13px;
    color: var(--t-3);
    line-height: 1.5;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-cta {
    font-size: 12px;
    color: var(--indigo);
    font-weight: 500;
    margin-top: auto;
  }

  /* Empty state */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 3rem 2rem;
    text-align: center;
    margin-top: 1rem;
  }

  .empty-icon {
    font-size: 2rem;
    color: var(--t-4);
  }

  .empty-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    color: var(--t-2);
  }

  .empty-desc {
    font-size: 13px;
    color: var(--t-3);
  }

  /* Dev.to section */
  .section-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 2.5rem 0 1rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--t-4);
    background: rgba(99,102,241,0.08);
    border: 1px solid rgba(99,102,241,0.18);
    padding: 3px 8px;
    border-radius: 3px;
  }

  .devto-badge {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.06em;
    color: #a78bfa;
    background: rgba(167,139,250,0.1);
    border: 1px solid rgba(167,139,250,0.2);
    padding: 2px 5px;
    border-radius: 3px;
  }

  .cover-img {
    width: 100%;
    height: 140px;
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: 0.25rem;
  }

  .tag-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 0.25rem;
  }

  .tag-chip {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--t-4);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    padding: 2px 6px;
    border-radius: 3px;
  }

  .post-stats {
    display: flex;
    gap: 10px;
    margin-top: auto;
    padding-top: 0.25rem;
  }

  .stat {
    font-size: 11px;
    color: var(--t-4);
    font-family: var(--font-mono);
  }

  .animate-in {
    animation: fadeUp 0.4s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
