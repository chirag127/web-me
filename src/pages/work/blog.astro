---
import Layout from '~/layouts/Layout.astro'
import { readFileSync } from 'fs'
import { join } from 'path'

let posts: any[] = []
try { posts = JSON.parse(readFileSync(join(process.cwd(), 'public/data/blog-posts.json'), 'utf-8')) } catch {}

function formatDate(dateStr: string): string {
  if (!dateStr) return ''
  try {
    return new Date(dateStr).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  } catch { return dateStr }
}
---

<Layout title="Writing" description="Technical articles on engineering and AI by Chirag Singhal">

  <div class="page-updated">DATA · 2026-07-07</div>

  <div class="kicker">WORK · WRITING</div>
  <h1 class="page-title">Writing</h1>
  <p class="page-subtitle">
    Technical articles on engineering and AI.
    <a href="https://blog.oriz.in" target="_blank" rel="noopener" class="blog-link">blog.oriz.in ↗</a>
  </p>

  {posts.length === 0 ? (
    <div class="card empty-state animate-in">
      <div class="empty-icon">▣</div>
      <div class="empty-title">No posts yet</div>
      <p class="empty-desc">Writing in progress. Check back soon or visit <a href="https://blog.oriz.in" target="_blank" rel="noopener" class="blog-link">blog.oriz.in</a>.</p>
    </div>
  ) : (
    <div class="posts-grid animate-in">
      {posts.map((post: any) => (
        <a href={post.link} target="_blank" rel="noopener" class="card post-card">
          <div class="post-meta">
            <span class="post-date">{formatDate(post.date)}</span>
          </div>
          <h2 class="post-title">{post.title}</h2>
          {post.desc && <p class="post-desc">{post.desc}</p>}
          <span class="post-cta">Read →</span>
        </a>
      ))}
    </div>
  )}

</Layout>

<style>
  .page-updated {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--t-4);
    letter-spacing: 0.05em;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: var(--t-1);
    margin: 0.5rem 0 0.5rem;
    background: linear-gradient(135deg, var(--indigo) 0%, #a78bfa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .page-subtitle {
    font-size: 16px;
    color: var(--t-3);
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .blog-link {
    color: var(--indigo);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
  }

  .blog-link:hover {
    color: #818cf8;
  }

  /* Posts */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    transition: border-color 120ms, background 80ms;
  }

  .post-card:hover {
    border-color: rgba(99,102,241,0.3);
    background: rgba(255,255,255,0.03);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--t-4);
  }

  .post-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    color: var(--t-1);
    line-height: 1.4;
  }

  .post-desc {
    font-size: 13px;
    color: var(--t-3);
    line-height: 1.5;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-cta {
    font-size: 12px;
    color: var(--indigo);
    font-weight: 500;
    margin-top: auto;
  }

  /* Empty state */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 3rem 2rem;
    text-align: center;
    margin-top: 1rem;
  }

  .empty-icon {
    font-size: 2rem;
    color: var(--t-4);
  }

  .empty-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    color: var(--t-2);
  }

  .empty-desc {
    font-size: 13px;
    color: var(--t-3);
  }

  .animate-in {
    animation: fadeUp 0.4s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
