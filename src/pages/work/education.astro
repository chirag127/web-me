---
import Layout from '~/layouts/Layout.astro'
---
<Layout title="Education" description="Chirag Singhal — education background">
  <div style="padding-top: 2rem; max-width: 600px;">
    <h1 class="page-title">Education</h1>
    <p class="page-sub">Academic background.</p>

    <div class="timeline">

      <div class="timeline-item">
        <div style="font-family:var(--font-mono);font-size:11px;color:var(--t-muted);margin-bottom:4px;">2021 – 2025</div>
        <div style="font-family:var(--font-display);font-weight:600;font-size:14px;color:#fff;">Dr. A.P.J. Abdul Kalam Technical University (AKTU)</div>
        <div style="font-size:13px;color:var(--t-secondary);margin-bottom:6px;">B.Tech — Computer Science &amp; Engineering</div>
        <div style="display:flex;gap:12px;">
          <div><span style="font-family:var(--font-display);font-weight:700;font-size:18px;color:#fff;">8.81</span><span style="font-size:11px;color:var(--t-muted);margin-left:4px;">CGPA · Rank 1</span></div>
        </div>
      </div>

      <div class="timeline-item">
        <div style="font-family:var(--font-mono);font-size:11px;color:var(--t-muted);margin-bottom:4px;">2021</div>
        <div style="font-family:var(--font-display);font-weight:600;font-size:14px;color:#fff;">CBSE Class XII</div>
        <div style="font-size:13px;color:var(--t-secondary);margin-bottom:6px;">Science (PCM)</div>
        <div style="display:flex;gap:12px;">
          <div><span style="font-family:var(--font-display);font-weight:700;font-size:18px;color:#fff;">97%</span></div>
          <div style="font-size:12px;color:var(--t-muted);align-self:flex-end;padding-bottom:2px;">JEE Advanced AIR 11870 · Top 1%</div>
        </div>
      </div>

    </div>
  </div>
</Layout>
