---
import Layout from '~/layouts/Layout.astro'
---

<Layout title="Login">
  <div id="login-wrap" style="display:flex;align-items:center;justify-content:center;min-height:80vh;padding:24px;">
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:40px 36px;max-width:400px;width:100%;">
      <div style="font-family:var(--font-display);font-size:1.4rem;font-weight:700;color:var(--t-primary);margin-bottom:6px;">Private access</div>
      <div style="color:var(--t-tertiary);font-size:0.875rem;margin-bottom:28px;">Enter your email to receive a magic link.</div>

      <form id="link-form" style="display:flex;flex-direction:column;gap:14px;">
        <input
          id="email-input"
          type="email"
          value="whyiswhen@gmail.com"
          placeholder="your@email.com"
          required
          style="height:42px;padding:0 14px;background:var(--overlay);border:1px solid var(--border);border-radius:8px;color:var(--t-primary);font-size:0.9rem;outline:none;transition:border-color 120ms;"
          onfocus="this.style.borderColor='#6366f1'"
          onblur="this.style.borderColor='var(--border)'"
        />
        <button
          type="submit"
          id="send-btn"
          style="height:42px;background:#6366f1;border:none;border-radius:8px;color:#fff;font-family:var(--font-display);font-weight:600;font-size:0.9rem;cursor:pointer;transition:background 120ms;"
          onmouseover="this.style.background='#4f46e5'"
          onmouseout="this.style.background='#6366f1'"
        >
          Send magic link
        </button>
      </form>

      <div id="status-msg" style="display:none;margin-top:20px;padding:12px 14px;border-radius:8px;font-size:0.875rem;"></div>
    </div>
  </div>

  <script>
    import { initializeApp, getApps } from 'firebase/app'
    import { getAuth, isSignInWithEmailLink, sendSignInLinkToEmail, signInWithEmailLink } from 'firebase/auth'

    const cfg = {
      apiKey:     import.meta.env.PUBLIC_FIREBASE_API_KEY,
      authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
      projectId:  import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
    }

    const app  = getApps().length ? getApps()[0] : initializeApp(cfg)
    const auth = getAuth(app)

    const statusEl = document.getElementById('status-msg')!
    const formEl   = document.getElementById('link-form')!

    function showMsg(text: string, ok: boolean) {
      statusEl.textContent = text
      statusEl.style.display  = 'block'
      statusEl.style.background = ok ? 'rgba(34,197,94,0.1)' : 'rgba(239,68,68,0.1)'
      statusEl.style.color      = ok ? '#4ade80'              : '#f87171'
      statusEl.style.border     = `1px solid ${ok ? 'rgba(34,197,94,0.3)' : 'rgba(239,68,68,0.3)'}`
    }

    // Handle incoming magic link
    if (isSignInWithEmailLink(auth, window.location.href)) {
      const email = localStorage.getItem('emailForSignIn') || prompt('Please confirm your email:') || ''
      formEl.style.display = 'none'
      showMsg('Signing you in…', true)
      signInWithEmailLink(auth, email, window.location.href)
        .then(() => {
          localStorage.removeItem('emailForSignIn')
          window.location.replace('/me/stats')
        })
        .catch((e: any) => showMsg('Sign-in failed: ' + e.message, false))
    }

    // Send magic link
    formEl.addEventListener('submit', async (e) => {
      e.preventDefault()
      const email  = (document.getElementById('email-input') as HTMLInputElement).value.trim()
      const btn    = document.getElementById('send-btn')!
      btn.textContent = 'Sending…'
      ;(btn as HTMLButtonElement).disabled = true
      try {
        await sendSignInLinkToEmail(auth, email, {
          url:             window.location.origin + '/login',
          handleCodeInApp: true,
        })
        localStorage.setItem('emailForSignIn', email)
        showMsg('Check your inbox — magic link sent!', true)
        formEl.style.display = 'none'
      } catch (err: any) {
        showMsg('Error: ' + err.message, false)
        btn.textContent = 'Send magic link'
        ;(btn as HTMLButtonElement).disabled = false
      }
    })
  </script>
</Layout>
