---
import Layout from '~/layouts/Layout.astro'
import { getBlogPosts } from '~/lib/api'

const posts = await getBlogPosts()

function formatDate(raw: string) {
  if (!raw) return ''
  const d = new Date(raw)
  return isNaN(d.getTime()) ? raw : d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
}
---

<Layout title="Writing" description="Essays and thoughts by Chirag Singhal" active="/writing/">
  <header style="margin-bottom:2rem">
    <p style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--primary);margin-bottom:0.4rem">Writing</p>
    <h1 style="font-family:var(--font-display);font-size:2rem;font-weight:800;color:var(--text);margin:0 0 0.4rem">Writing</h1>
    <p style="color:var(--muted);font-size:0.95rem;margin:0">
      Essays at <a href="https://blog.oriz.in" target="_blank" rel="noopener" style="color:var(--primary);text-decoration:none;border-bottom:1px solid var(--primary-dim)">blog.oriz.in</a>
    </p>
  </header>

  {posts.length > 0 ? (
    <ul style="list-style:none;display:flex;flex-direction:column;gap:1rem">
      {posts.map(post => (
        <li>
          <a
            href={post.link || 'https://blog.oriz.in'}
            target="_blank"
            rel="noopener"
            style="display:block;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1.25rem 1.5rem;text-decoration:none;transition:border-color 150ms"
            onmouseover="this.style.borderColor='var(--primary)'"
            onmouseout="this.style.borderColor='var(--border)'"
          >
            <div style="display:flex;align-items:baseline;justify-content:space-between;gap:1rem;margin-bottom:0.4rem;flex-wrap:wrap">
              <span style="font-family:var(--font-display);font-size:1.05rem;font-weight:600;color:var(--text)">{post.title}</span>
              {post.date && (
                <time style="font-size:0.75rem;color:var(--faint);white-space:nowrap;flex-shrink:0">{formatDate(post.date)}</time>
              )}
            </div>
            {post.desc && (
              <p style="font-size:0.875rem;color:var(--muted);margin:0;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">{post.desc}</p>
            )}
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <div style="border:1px dashed var(--border);border-radius:var(--radius);padding:3rem 2rem;text-align:center">
      <p style="color:var(--muted);margin:0 0 0.75rem;font-size:0.95rem">No posts loaded yet.</p>
      <a href="https://blog.oriz.in" target="_blank" rel="noopener" style="color:var(--primary);font-size:0.875rem;text-decoration:none;border-bottom:1px solid var(--primary-dim)">Visit blog.oriz.in →</a>
    </div>
  )}
</Layout>
