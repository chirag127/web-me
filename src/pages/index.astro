---
import Layout from '~/layouts/Layout.astro'
import { getLanyard, getLastfmRecent, getGitHubStats } from '~/lib/api'

const [lanyard, lfRecent, ghStats] = await Promise.all([
  getLanyard(),
  getLastfmRecent(1),
  getGitHubStats(),
])

// Discord status
const discordStatus = lanyard?.discord_status ?? 'offline'
const statusColors: Record<string, string> = {
  online:  '#22c55e',
  idle:    '#f59e0b',
  dnd:     '#ef4444',
  offline: '#525260',
}
const statusColor = statusColors[discordStatus] ?? statusColors.offline
const statusLabel: Record<string, string> = {
  online:  'Online',
  idle:    'Away',
  dnd:     'Do not disturb',
  offline: 'Offline',
}

const discordActivity = lanyard?.listening_to_spotify
  ? `Listening to ${lanyard.spotify?.song} — ${lanyard.spotify?.artist}`
  : lanyard?.activities?.find((a: any) => a.type === 0)?.name
    ? `Playing ${lanyard.activities.find((a: any) => a.type === 0)?.name}`
    : null

// Last.fm now playing
const track = lfRecent[0]
const isNowPlaying = track?.['@attr']?.nowplaying === 'true'
const npTrack  = isNowPlaying ? (track?.name ?? '') : ''
const npArtist = isNowPlaying ? (track?.artist?.['#text'] ?? '') : ''

const STATS = [
  { label: 'Years Experience', value: '2+' },
  { label: 'Tools Built (oriz.in)', value: '192+' },
  { label: 'CGPA · Rank 1', value: '8.81' },
  { label: 'JEE Advanced', value: 'Top 1%' },
]

const NAV_GRID = [
  { href: '/work/',     label: 'Work' },
  { href: '/projects/', label: 'Projects' },
  { href: '/skills/',   label: 'Skills' },
  { href: '/about/',    label: 'About' },
  { href: '/contact/',  label: 'Contact' },
  { href: '/media/',    label: 'Media' },
]
---

<Layout title="Home" description="Chirag Singhal — Software Engineer. Full Stack, Backend & Distributed Systems Specialist." active="/">

  <!-- ── HERO ──────────────────────────────────────────────────── -->
  <section class="hero">
    <p class="kicker">SOFTWARE ENGINEER</p>
    <h1 class="hero-name">Chirag Singhal</h1>
    <p class="hero-role">Full Stack · Backend · Distributed Systems · AI</p>
    <p class="hero-bio">Building scalable systems across the full SDLC. Currently at TCS.</p>

    <!-- Discord status strip -->
    {lanyard && (
      <div class="status-strip">
        <span class="status-dot" style={`background:${statusColor}`}></span>
        <span class="status-text">
          {discordActivity ?? statusLabel[discordStatus]}
          {' — Discord'}
        </span>
      </div>
    )}

    <!-- CTA row -->
    <div class="cta-row">
      <a href="/work/" class="cta-primary">View Work →</a>
      <a href="https://github.com/chirag127/me/releases/latest/download/resume.pdf" class="cta-link" target="_blank" rel="noopener">Download Resume ↓</a>
      <a href="https://github.com/chirag127" class="cta-link" target="_blank" rel="noopener">GitHub ↗</a>
      <a href="https://linkedin.com/in/chirag127" class="cta-link" target="_blank" rel="noopener">LinkedIn ↗</a>
    </div>
  </section>

  <!-- ── QUICK STATS ───────────────────────────────────────────── -->
  <section class="section-gap">
    <div class="stats-grid">
      {STATS.map(s => (
        <div class="stat-card">
          <span class="stat-value">{s.value}</span>
          <span class="stat-label">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ── RECENT ACTIVITY ───────────────────────────────────────── -->
  <section class="section-gap">
    <p class="kicker">LATELY</p>
    <ul class="activity-list">
      <li class="activity-item">
        <span class="activity-dot"></span>
        <span>Software Engineer at <strong>TCS</strong> — since Jun 2025</span>
      </li>
      {npTrack && (
        <li class="activity-item">
          <span class="activity-dot"></span>
          <span>Now playing: <strong>{npTrack}</strong> by {npArtist}</span>
        </li>
      )}
    </ul>
  </section>

  <!-- ── NAV GRID ──────────────────────────────────────────────── -->
  <section class="section-gap">
    <div class="nav-grid">
      {NAV_GRID.map(n => (
        <a href={n.href} class="nav-card">
          <span>{n.label}</span>
        </a>
      ))}
    </div>
  </section>

</Layout>

<style>
/* ── typography tokens ─── */
:root {
  --font-body:    Charter, "Bitstream Charter", Cambria, Georgia, serif;
  --font-ui:      ui-monospace, monospace;
  --font-display: system-ui, sans-serif;
  --bg:      #0f0f11;
  --paper:   #141416;
  --raised:  #1a1a1e;
  --fg:      #eaeaec;
  --muted:   #9b9ba3;
  --faint:   #525260;
  --accent:  #0066cc;
  --rule:    rgba(255,255,255,0.10);
}

/* ── hero ─── */
.hero {
  padding-bottom: 2.5rem;
  border-bottom: 1px solid var(--rule);
  margin-bottom: 2.5rem;
}

.kicker {
  font-family: var(--font-ui);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--muted);
  margin: 0 0 0.75rem;
}

.hero-name {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 600;
  letter-spacing: -0.02em;
  color: var(--fg);
  margin: 0 0 0.4rem;
  line-height: 1.1;
}

.hero-role {
  font-family: var(--font-body);
  font-size: 1rem;
  color: var(--muted);
  margin: 0 0 0.6rem;
}

.hero-bio {
  font-family: var(--font-body);
  font-size: 0.9375rem;
  color: var(--fg);
  max-width: 60ch;
  margin: 0 0 1.25rem;
}

/* status strip */
.status-strip {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: var(--paper);
  border: 1px solid var(--rule);
  border-radius: 6px;
  padding: 0.3rem 0.75rem;
  margin-bottom: 1.5rem;
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.status-text {
  font-family: var(--font-ui);
  font-size: 0.75rem;
  color: var(--muted);
}

/* CTA row */
.cta-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 1rem;
}

.cta-primary {
  font-family: var(--font-ui);
  font-size: 0.8125rem;
  color: var(--fg);
  background: var(--raised);
  border: 1px solid var(--rule);
  border-radius: 6px;
  padding: 0.45rem 1rem;
  text-decoration: none;
}

.cta-primary:hover {
  border-color: rgba(255,255,255,0.25);
  text-decoration: none;
}

.cta-link {
  font-family: var(--font-ui);
  font-size: 0.8125rem;
  color: var(--accent);
  text-decoration: underline;
  text-underline-offset: 0.2em;
  text-decoration-thickness: 1px;
}

.cta-link:hover {
  color: var(--fg);
}

/* ── stats ─── */
.section-gap {
  margin-bottom: 2.5rem;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
}

.stat-card {
  background: var(--paper);
  border: 1px solid var(--rule);
  border-radius: 6px;
  padding: 1rem 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.stat-value {
  font-family: var(--font-display);
  font-size: 1.75rem;
  font-weight: 600;
  letter-spacing: -0.02em;
  color: var(--accent);
  line-height: 1;
}

.stat-label {
  font-family: var(--font-ui);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--muted);
}

/* ── activity ─── */
.activity-list {
  list-style: none;
  padding: 0;
  margin: 0.75rem 0 0;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.activity-item {
  display: flex;
  align-items: baseline;
  gap: 0.6rem;
  font-family: var(--font-body);
  font-size: 0.9rem;
  color: var(--fg);
}

.activity-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
  position: relative;
  top: -1px;
}

/* ── nav grid ─── */
.nav-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
}

.nav-card {
  background: var(--paper);
  border: 1px solid var(--rule);
  border-radius: 6px;
  padding: 0.875rem 1rem;
  font-family: var(--font-ui);
  font-size: 0.8125rem;
  color: var(--muted);
  text-decoration: none;
  display: flex;
  align-items: center;
}

.nav-card:hover {
  border-color: rgba(255,255,255,0.22);
  color: var(--fg);
  text-decoration: none;
}

/* ── responsive ─── */
@media (max-width: 640px) {
  .stats-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .nav-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .stat-value {
    font-size: 1.5rem;
  }
}
</style>
