---
import Layout from '~/layouts/Layout.astro'
import { getLanyard, getLastfmRecent, getGitHubStats } from '~/lib/api'

const [lanyard, lfRecent, ghStats] = await Promise.all([
  getLanyard(),
  getLastfmRecent(1),
  getGitHubStats(),
])

const discordStatus = lanyard?.discord_status ?? 'offline'
const track = lfRecent[0]
const isNowPlaying = track?.['@attr']?.nowplaying === 'true'

const STATS = [
  { value: '2+',    label: 'YRS EXP' },
  { value: '192+',  label: 'TOOLS BUILT' },
  { value: '8.81',  label: 'CGPA RANK 1' },
  { value: 'Top 1%',label: 'JEE ADVANCED' },
]

const EXPLORE = [
  { href: '/work/career',   icon: '◈', label: 'Work' },
  { href: '/work/projects', icon: '◧', label: 'Projects' },
  { href: '/work/skills',   icon: '≡', label: 'Skills' },
  { href: '/library/music', icon: '♪', label: 'Music' },
  { href: '/me',            icon: '◉', label: 'About' },
  { href: '/connect/contact',icon: '◌', label: 'Contact' },
]
---

<Layout title="Home" description="Chirag Singhal — Software Engineer · Backend · AI Systems · Open Source">

  <!-- Hero -->
  <section style="padding-top: 3rem; max-width: 680px;">

    <!-- Status pill -->
    <div style="display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:9999px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.10);">
      <span class="pulse-dot"></span>
      <span style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:#818cf8;">Software Engineer · TCS</span>
    </div>

    <!-- H1 -->
    <h1 style="margin-top:1rem;margin-bottom:0.75rem;font-family:var(--font-display);font-weight:800;font-size:clamp(2.2rem,4vw,3.5rem);line-height:1.1;letter-spacing:-0.03em;">
      Building scalable<br>
      <span class="gradient-text">backend systems</span><br>
      &amp; intelligent APIs.
    </h1>

    <!-- Subtitle -->
    <p style="font-size:14px;color:var(--t-secondary);max-width:540px;margin-bottom:1.5rem;">
      Full Stack · Backend · AI Systems · Open Source
    </p>

    <!-- CTAs -->
    <div style="display:flex;flex-wrap:wrap;gap:12px;align-items:center;margin-bottom:0.75rem;">
      <a href="/work/career" style="background:#fff;color:#000;font-weight:600;font-size:14px;padding:8px 20px;border-radius:8px;text-decoration:none;">View Work →</a>
      <a href="/resume.pdf" style="background:rgba(99,102,241,0.08);color:#818cf8;border:1px solid rgba(99,102,241,0.2);font-size:14px;padding:8px 20px;border-radius:8px;text-decoration:none;">Download Resume ↓</a>
      <a href="https://github.com/chirag127" target="_blank" rel="noopener" style="font-size:14px;color:var(--t-tertiary);text-decoration:none;transition:color 80ms;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='var(--t-tertiary)'">GitHub ↗</a>
      <a href="https://linkedin.com/in/chirag127" target="_blank" rel="noopener" style="font-size:14px;color:var(--t-tertiary);text-decoration:none;transition:color 80ms;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='var(--t-tertiary)'">LinkedIn ↗</a>
    </div>

    <!-- Discord strip -->
    <div style="display:flex;align-items:center;gap:8px;font-size:12px;color:var(--t-muted);">
      <span style="width:6px;height:6px;border-radius:50%;background:var(--t-muted);display:inline-block;flex-shrink:0;"></span>
      <span>{discordStatus === 'offline' ? 'Offline' : discordStatus === 'online' ? 'Online' : discordStatus === 'idle' ? 'Away' : 'DND'} · Discord</span>
    </div>

  </section>

  <!-- Stats strip -->
  <div class="section" style="display:flex;align-items:center;gap:0;">
    {STATS.map((s, i) => (
      <>
        <div style="display:flex;flex-direction:column;gap:2px;padding: 0 24px 0 0;">
          <span style="font-family:var(--font-display);font-weight:700;font-size:1.5rem;color:#fff;line-height:1;">{s.value}</span>
          <span style="font-size:10px;font-weight:500;text-transform:uppercase;letter-spacing:0.08em;color:var(--t-muted);">{s.label}</span>
        </div>
        {i < STATS.length - 1 && <div style="width:1px;height:32px;background:rgba(255,255,255,0.08);flex-shrink:0;margin-right:24px;"></div>}
      </>
    ))}
  </div>

  <!-- Recently -->
  <div class="section">
    <span class="kicker">RECENTLY</span>
    <div>
      {[
        { text: 'Software Engineer @ TCS', date: 'Jun 2025' },
        { text: '192+ tools shipped (oriz.in)', date: 'Ongoing' },
        { text: 'AWS Developer Associate', date: '2025' },
      ].map(item => (
        <div style="display:flex;align-items:center;height:28px;gap:10px;border-bottom:1px solid var(--border);">
          <span style="width:4px;height:4px;border-radius:50%;background:#6366f1;flex-shrink:0;"></span>
          <span style="font-size:13px;color:var(--t-secondary);flex:1;">{item.text}</span>
          <span style="font-size:11px;color:var(--t-muted);font-family:var(--font-mono);">{item.date}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Explore -->
  <div class="section">
    <span class="kicker">EXPLORE</span>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;">
      {EXPLORE.map(e => (
        <a href={e.href} class="explore-card">
          <span class="eicon">{e.icon}</span>
          <span class="elabel">{e.label}</span>
        </a>
      ))}
    </div>
  </div>

</Layout>
