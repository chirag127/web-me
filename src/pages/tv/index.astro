---
import Layout from '~/layouts/Layout.astro'
import { getTraktShows, getTraktStats } from '~/lib/api'

const [history, stats] = await Promise.all([getTraktShows(40), getTraktStats()])

// Deduplicate: keep only the most recent history entry per show
const seen = new Set<number>()
const shows: any[] = []
for (const entry of history) {
  const id = entry.show?.ids?.trakt
  if (id == null || seen.has(id)) continue
  seen.add(id)
  shows.push(entry)
}

const showCount  = stats?.shows?.watched ?? shows.length
const epCount    = stats?.episodes?.watched ?? 0
const minutes    = stats?.episodes?.minutes ?? 0
const hours      = Math.round(minutes / 60)
---

<Layout title="TV Shows" active="/tv/">
  <!-- Header -->
  <div style="margin-bottom:2rem">
    <p style="color:var(--primary);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.4rem">Entertainment</p>
    <h1 style="font-family:var(--font-display);font-size:2rem;font-weight:800;margin:0 0 0.25rem">TV Shows</h1>
    <p style="color:var(--muted);font-size:0.9rem">Tracked via Trakt</p>
  </div>

  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:2rem">
    {[
      { label: 'Shows', value: showCount },
      { label: 'Episodes', value: epCount.toLocaleString() },
      { label: 'Hours', value: hours.toLocaleString() },
    ].map(s => (
      <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1.25rem 1rem;text-align:center">
        <div style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--primary)">{s.value}</div>
        <div style="font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);margin-top:0.25rem">{s.label}</div>
      </div>
    ))}
  </div>

  <!-- Shows grid -->
  <p style="color:var(--primary);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:1rem">Recent Shows</p>

  {shows.length === 0 ? (
    <div style="border:1px dashed var(--border);border-radius:var(--radius);padding:3rem;text-align:center;color:var(--muted)">
      No shows found
    </div>
  ) : (
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:1rem">
      {shows.map(entry => {
        const show = entry.show
        const year = show?.year ?? ''
        const ep   = entry.episode
        const s    = ep?.season  != null ? `S${String(ep.season).padStart(2,'0')}` : ''
        const e    = ep?.number  != null ? `E${String(ep.number).padStart(2,'0')}` : ''
        return (
          <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;transition:border-color 120ms"
               onmouseenter="this.style.borderColor='var(--primary)'"
               onmouseleave="this.style.borderColor='var(--border)'">
            <!-- Poster placeholder -->
            <div style="background:var(--raised,#111);aspect-ratio:2/3;display:flex;align-items:center;justify-content:center;font-size:2rem">
              📺
            </div>
            <div style="padding:0.6rem 0.75rem 0.75rem">
              <div style="font-size:0.82rem;font-weight:600;line-height:1.3;margin-bottom:0.2rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title={show?.title}>
                {show?.title}
              </div>
              <div style="font-size:0.72rem;color:var(--muted)">{year}</div>
              {(s || e) && (
                <div style="font-size:0.68rem;color:var(--primary);margin-top:0.3rem;font-family:var(--font-display)">{s}{e}</div>
              )}
            </div>
          </div>
        )
      })}
    </div>
  )}
</Layout>
